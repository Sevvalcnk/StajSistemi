@{
    ViewData["Title"] = "Erişim Engellendi";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4 p-5 text-center bg-white">
                @* Kırmızı Kilit İkonu *@
                <div class="mb-4">
                    <i class="fas fa-user-lock fa-5x text-danger animate__animated animate__shakeX"></i>
                </div>

                <h2 class="fw-bold text-dark">Erişim Engellendi!</h2>
                <p class="text-muted mb-4">
                    Bu sayfayı görüntülemek için gerekli yetkiye sahip değilsiniz.
                    Lütfen doğru hesapla giriş yaptığınızdan emin olun.
                </p>

                @* Tek ve Şık Bir Buton *@
                <a href="/" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow">
                    <i class="fas fa-home me-2"></i>Ana Sayfaya Dön
                </a>
            </div>
        </div>
    </div>
</div>