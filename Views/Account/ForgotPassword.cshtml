@{
    ViewData["Title"] = "Şifremi Unuttum";
}
<div class="container py-5 text-center">
    <div class="card p-4 shadow-sm border-0 rounded-4 mx-auto" style="max-width: 400px;">
        <i class="fas fa-key fa-3x text-warning mb-3"></i>
        <h3>Şifremi Unuttum</h3>
        <p class="text-muted small">E-posta adresinizi girin, sıfırlama linkini gönderelim.</p>
        <form asp-action="ForgotPassword" method="post">
            <input name="email" type="email" class="form-control rounded-pill mb-3 text-center" placeholder="mail@sinop.edu.tr" required />
            <button type="submit" class="btn btn-primary w-100 rounded-pill">Bağlantı Gönder</button>
        </form>
    </div>
</div>