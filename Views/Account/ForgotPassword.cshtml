@model StajSistemi.Models.ViewModels.LoginViewModel
@* Not: Model tanımlaması en üstte tek başına durmalı *@

@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">

            <div class="card shadow-lg border-0 rounded-4 p-4 text-center" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">

                <div class="mb-3">
                    <div class="icon-circle bg-light d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 80px; height: 80px;">
                        <i class="fas fa-key fa-2x text-warning"></i>
                    </div>
                </div>

                <h2 class="fw-bold" style="color: #2c3e50;">Şifremi Unuttum</h2>
                <p class="text-muted small mb-4">Kayıtlı e-posta adresinizi girin, size sıfırlama bağlantısını hemen gönderelim.</p>

                @* ✅ MÜHÜR: Başarı mesajı *@
                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success border-0 rounded-pill small mb-4 shadow-sm">
                        <i class="fas fa-check-circle me-2"></i> @ViewBag.Message
                    </div>
                }

                <form asp-controller="Account" asp-action="ForgotPassword" method="post">
                    <div class="mb-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0" style="border-top-left-radius: 50px; border-bottom-left-radius: 50px;">
                                <i class="fas fa-envelope text-muted"></i>
                            </span>
                            <input name="email" type="email" class="form-control border-start-0"
                                   placeholder="mail@sinop.edu.tr" required
                                   style="border-top-right-radius: 50px; border-bottom-right-radius: 50px; height: 50px;" />
                        </div>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm"
                                style="background: linear-gradient(to right, #2c3e50, #4ca1af); border: none;">
                            Bağlantı Gönder
                        </button>
                    </div>
                </form>

                <div class="mt-2">
                    <a href="/Account/Login" class="text-decoration-none small fw-bold text-primary">
                        <i class="fas fa-arrow-left me-1"></i> Giriş Sayfasına Dön
                    </a>
                </div>
            </div>

            <p class="text-center mt-4 text-muted small">© 2026 Sinop Üniversitesi Staj Sistemi</p>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.6)), url('https://images.unsplash.com/photo-1434030216411-0b793f4b4173?auto=format&fit=crop&w=1920&q=80');
        background-size: cover;
        background-attachment: fixed;
        min-height: 100vh;
    }

    .icon-circle {
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }
</style>