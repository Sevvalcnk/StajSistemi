@model StajSistemi.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
    // Seçili rolü kontrol ediyoruz
    bool isStudent = ViewBag.SelectedRole == "Student" || ViewBag.SelectedRole == "Öğrenci";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
    }

    .premium-input:focus {
        border-color: #4ca1af;
        box-shadow: 0 0 10px rgba(76, 161, 175, 0.2);
    }

    .input-group-text {
        cursor: pointer;
        transition: color 0.2s;
    }

        .input-group-text:hover i {
            color: #4ca1af !important;
        }

    .techNode-fade-in {
        animation: fadeIn 0.8s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="container py-5 techNode-fade-in">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card glass-card p-4 border-0 shadow-lg rounded-4">
                <div class="card-header bg-white border-0 pt-2 text-center">
                    <div class="mb-3">
                        <i class="fas @(isStudent ? "fa-user-graduate" : "fa-user-tie") fa-3x text-primary" style="color: #2c3e50 !important;"></i>
                    </div>
                    <h3 class="fw-bold" style="color: #2c3e50;">
                        @(isStudent ? "Öğrenci Girişi" : "Personel Girişi")
                    </h3>
                    <p class="text-muted small">Lütfen bilgilerinizi kontrol ederek giriş yapın.</p>
                </div>

                @* 🛡️ GÜVENLİK KİLİDİ MÜHRÜ *@
                <div class="px-3 mb-2">
                    <div class="alert alert-dark border-0 shadow-sm rounded-4 p-3" style="background-color: #2c3e50; color: #ecf0f1;">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-user-shield fa-2x me-3 text-warning"></i>
                            <div>
                                <h6 class="fw-bold mb-1" style="color: #f1c40f; font-size: 0.9rem;">Güvenlik Kilidi Aktif!</h6>
                                <p class="small mb-0" style="font-size: 0.75rem; line-height: 1.3;">
                                    Yetkisiz erişim engellenmiş olur. Yani bilgisayar başında biri oturumu açık bırakıp gitse bile, süre dolunca sistem kendini dış dünyaya kapatır. 🛡️
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-body pt-0">
                    <form asp-action="Login" asp-route-role="@ViewBag.SelectedRole" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold small">
                                @(isStudent ? "Öğrenci Numarası" : "E-posta Adresi")
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-top-left-radius: 50px; border-bottom-left-radius: 50px;">
                                    <i class="fas @(isStudent ? "fa-id-card" : "fa-envelope") text-muted"></i>
                                </span>
                                <input asp-for="Email" class="form-control border-start-0 premium-input"
                                       placeholder="@(isStudent ? "Örn: 247017025" : "adiniz@sinop.edu.tr")"
                                       style="border-top-right-radius: 50px; border-bottom-right-radius: 50px;" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label asp-for="Password" class="form-label fw-bold small">Şifre</label>
                                <a href="/Account/ForgotPassword" class="text-primary small fw-bold text-decoration-none">Şifremi Unuttum?</a>
                            </div>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-top-left-radius: 50px; border-bottom-left-radius: 50px;">
                                    <i class="fas fa-lock text-muted"></i>
                                </span>
                                <input asp-for="Password" type="password" id="passInput" class="form-control border-start-0 border-end-0 premium-input" placeholder="******" />
                                <span class="input-group-text bg-white border-start-0" onclick="togglePassword('passInput', 'toggleIcon')" style="border-top-right-radius: 50px; border-bottom-right-radius: 50px;">
                                    <i class="fas fa-eye text-muted" id="toggleIcon"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label small text-muted">Beni Hatırla (30 Gün)</label>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm"
                                    style="background: linear-gradient(to right, #2c3e50, #4ca1af); border: none;">
                                Giriş Yap
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-white border-0 py-3 text-center">
                    @* ✅ MÜHÜR: Buradaki kısıtlamayı kaldırdık, artık personel için de kayıt linki görünecek *@
                    <p class="mb-0 small text-muted">
                        Hesabınız yok mu?
                        <a asp-action="Register" asp-route-role="@ViewBag.SelectedRole" class="text-primary fw-bold text-decoration-none">
                            <i class="fas fa-user-plus me-1"></i> Hemen Kayıt Ol
                        </a>
                    </p>

                    @* OTURUM GÜVENLİĞİ ZAMANLAYICI *@
                    <div class="mt-4">
                        <div class="d-inline-block px-3 py-1 rounded-pill bg-light border shadow-sm" style="font-size: 0.7rem;">
                            <span class="text-muted fw-bold">
                                <i class="fas fa-clock me-1 text-danger"></i>
                                Oturum Güvenliği: <span id="timer" class="text-dark">05:00</span>
                            </span>
                        </div>
                    </div>

                    <a href="/" class="text-muted small text-decoration-none mt-3 d-block">
                        <i class="fas fa-arrow-left me-1"></i> Portal Sayfasına Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Şifre Göster/Gizle
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = "password";
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        // ✅ Gelişmiş Geri Sayım Motoru (Sert Kilit Modu)
        let timeLeft = 300;
        const timerElement = document.getElementById('timer');

        const countdown = setInterval(() => {
            let minutes = Math.floor(timeLeft / 60);
            let seconds = timeLeft % 60;

            seconds = seconds < 10 ? '0' + seconds : seconds;
            minutes = minutes < 10 ? '0' + minutes : minutes;

            timerElement.innerHTML = `${minutes}:${seconds}`;

            if (timeLeft <= 0) {
                clearInterval(countdown);
                document.body.innerHTML = `
                    <div style="height:100vh; display:flex; align-items:center; justify-content:center; background:#1a1a1a; color:white; text-align:center; font-family:sans-serif; position:fixed; top:0; left:0; width:100%; z-index:9999;">
                        <div>
                            <i class="fas fa-user-lock fa-5x text-danger mb-4"></i>
                            <h1 style="font-weight:bold; font-size: 2.5rem; margin-bottom: 15px;">OTURUM SÜRESİ DOLDU!</h1>
                            <p style="font-size: 1.2rem; opacity: 0.8;">Güvenlik kilidi devreye girdi. Yetkisiz erişim engellendi. 🛡️</p>
                            <a href="/Account/Login" class="btn btn-warning rounded-pill px-5 py-3 mt-4 fw-bold shadow-lg" style="text-decoration:none; color:#1a1a1a; background-color:#f1c40f; border:none; display:inline-block;">
                                <i class="fas fa-sync-alt me-2"></i> Yeniden Giriş Yap
                            </a>
                        </div>
                    </div>
                `;
            }
            timeLeft--;
        }, 1000);
    </script>
}