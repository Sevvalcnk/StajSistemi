@model StajSistemi.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Yeni Kayıt";
    bool canRegister = true;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .premium-input:focus {
        border-color: #4ca1af;
        box-shadow: 0 0 10px rgba(76, 161, 175, 0.2);
    }

    .input-group-text {
        cursor: pointer;
        transition: all 0.2s;
    }

        .input-group-text:hover {
            background-color: #f8f9fa !important;
            color: #4ca1af !important;
        }

    #studentNoArea {
        transition: opacity 0.3s ease, transform 0.3s ease;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center align-items-center g-5">

        @* SOL TARAF: İLLÜSTRASYON *@
        <div class="col-lg-5 d-none d-lg-block text-center">
            <img src="https://cdni.iconscout.com/illustration/premium/thumb/online-registration-4488061-3738526.png"
                 alt="Kayıt Ol" class="img-fluid" style="max-height: 450px;">
            <div class="mt-4">
                <h2 class="fw-bold" style="color: #2c3e50;">Aramıza Katıl!</h2>
                <p class="text-muted fs-5">Sisteme kayıt olarak staj sürecini profesyonelce yönetmeye başla.</p>
            </div>
        </div>

        @* SAĞ TARAF: KAYIT FORMU *@
        <div class="col-lg-6 col-xl-5">
            <div class="card glass-card p-4 border-0 shadow-lg rounded-4">

                <div class="alert alert-dark border-0 rounded-4 mb-4" style="background-color: #2c3e50; color: white;">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-shield-alt fa-2x me-3 text-warning"></i>
                        <div>
                            <h6 class="fw-bold mb-1">Güvenlik Protokolü Aktif!</h6>
                            <p class="small mb-0 opacity-75">Hızlı kayıt modundasın. Detaylı okul bilgilerini içeride profilinden mühürleyebilirsin. 🛡️</p>
                        </div>
                    </div>
                </div>

                <div class="text-center mb-4">
                    <h3 class="fw-bold">Yeni Kullanıcı Kaydı</h3>
                    <p class="text-muted small">Lütfen bilgilerinizi eksiksiz doldurun.</p>
                </div>

                <form asp-action="Register" method="post" id="registerForm">
                    @* 🛡️ KRİTİK DOKUNUŞ: 'ModelOnly' yerine 'All' yaptık ki tüm hataları (Şifre zayıf, Boş alan vs.) görelim *@
                    <div asp-validation-summary="All" class="text-danger mb-3 small"></div>

                    @* ✅ ROL SEÇİMİ *@
                    <div class="mb-3">
                        <label asp-for="Role" class="form-label fw-bold small">Kayıt Tipi (Yetki)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fas fa-user-tag text-muted"></i></span>
                            <select asp-for="Role" id="roleSelect" class="form-select border-start-0 premium-input">
                                <option value="Student">Öğrenci</option>
                                <option value="Advisor">Danışman (Hoca)</option>
                                <option value="Admin">Admin (Yönetici)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-bold small">Ad Soyad</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fas fa-user text-muted"></i></span>
                            <input asp-for="FullName" class="form-control border-start-0 premium-input" placeholder="Adınız Soyadınız" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    @* 🆔 ÖĞRENCİ NUMARASI *@
                    <div class="mb-3" id="studentNoArea">
                        <label asp-for="StudentNo" class="form-label fw-bold small">Öğrenci Numarası</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fas fa-id-card text-muted"></i></span>
                            <input asp-for="StudentNo" id="studentNoInput" class="form-control border-start-0 premium-input" placeholder="Örn: 247017029" />
                        </div>
                        <span asp-validation-for="StudentNo" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold small">E-posta Adresi</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control border-start-0 premium-input" placeholder="ornek@alanadi.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    @* 🔑 ŞİFRELER *@
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label fw-bold small">Şifre</label>
                            <div class="input-group">
                                <input asp-for="Password" type="password" id="passInput" class="form-control premium-input border-end-0 rounded-start" placeholder="******" />
                                <span class="input-group-text bg-white border-start-0" onclick="togglePassword('passInput', 'toggleIcon')">
                                    <i class="fas fa-eye text-muted" id="toggleIcon"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold small">Şifre Tekrar</label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" type="password" id="confirmPassInput" class="form-control premium-input border-end-0 rounded-start" placeholder="******" />
                                <span class="input-group-text bg-white border-start-0" onclick="togglePassword('confirmPassInput', 'confirmToggleIcon')">
                                    <i class="fas fa-eye text-muted" id="confirmToggleIcon"></i>
                                </span>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm"
                                style="background: linear-gradient(to right, #2c3e50, #4ca1af); border: none;">
                            <i class="fas fa-user-plus me-2"></i> Kaydı Tamamla
                        </button>
                    </div>
                </form>

                <div class="mt-4 text-center">
                    <p class="mb-0 small text-muted">Zaten hesabın var mı? <a href="/Account/Login" class="text-primary fw-bold text-decoration-none">Giriş Yap</a></p>
                    <a href="/" class="text-muted small text-decoration-none mt-3 d-block">
                        <i class="fas fa-home me-1"></i> Ana Sayfaya Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = "password";
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        const roleSelect = document.getElementById('roleSelect');
        const studentNoArea = document.getElementById('studentNoArea');
        const studentNoInput = document.getElementById('studentNoInput');

        function updateFormFields() {
            if (roleSelect.value === 'Student') {
                studentNoArea.style.display = 'block';
                setTimeout(() => { studentNoArea.style.opacity = '1'; }, 10);
            } else {
                studentNoArea.style.opacity = '0';
                studentNoArea.style.display = 'none';
                // studentNoInput.value = ""; // Rol değiştiğinde numarayı silmek istersen aktif edebilirsin
            }
        }

        roleSelect.addEventListener('change', updateFormFields);
        window.addEventListener('load', updateFormFields);
    </script>
}