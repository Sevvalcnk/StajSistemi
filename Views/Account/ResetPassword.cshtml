@model StajSistemi.Models.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Şifre Sıfırlama";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container py-5 techNode-fade-in">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 p-4 bg-white">
                <div class="text-center mb-4">
                    <div class="mb-3">
                        <i class="fas fa-user-shield fa-3x text-success"></i>
                    </div>
                    <h3 class="fw-bold" style="color: #2c3e50;">Yeni Şifre Belirle</h3>
                    <p class="text-muted small">Lütfen yeni ve güvenli bir şifre giriniz.</p>
                </div>

                <form asp-action="ResetPassword" method="post">
                    @* ✅ MÜHÜR: Controller'dan gelen verileri modele aktarıyoruz *@
                    <input type="hidden" name="Email" value="@ViewBag.Email" />
                    <input type="hidden" name="Token" value="@ViewBag.Token" />

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label small fw-bold">Yeni Şifre</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 rounded-start-pill" style="border-top-left-radius: 50px; border-bottom-left-radius: 50px;">
                                <i class="fas fa-lock text-muted"></i>
                            </span>
                            <input asp-for="Password" type="password" id="newPass" class="form-control border-start-0 border-end-0" placeholder="Yeni Şifre" />
                            <button class="btn btn-outline-light border-start-0 text-muted rounded-end-pill" type="button" onclick="togglePass('newPass', 'eye1')" style="border-top-right-radius: 50px; border-bottom-right-radius: 50px; border: 1px solid #ced4da; border-left: none;">
                                <i class="fas fa-eye" id="eye1"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label small fw-bold">Şifre Tekrar</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 rounded-start-pill" style="border-top-left-radius: 50px; border-bottom-left-radius: 50px;">
                                <i class="fas fa-check-double text-muted"></i>
                            </span>
                            <input asp-for="ConfirmPassword" type="password" id="confirmPass" class="form-control border-start-0 border-end-0" placeholder="Şifre Tekrar" />
                            <button class="btn btn-outline-light border-start-0 text-muted rounded-end-pill" type="button" onclick="togglePass('confirmPass', 'eye2')" style="border-top-right-radius: 50px; border-bottom-right-radius: 50px; border: 1px solid #ced4da; border-left: none;">
                                <i class="fas fa-eye" id="eye2"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold mt-3 py-2 shadow-sm"
                            style="background: linear-gradient(to right, #11998e, #38ef7d); border: none;">
                        Şifreyi Güncelle
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = "password";
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
}