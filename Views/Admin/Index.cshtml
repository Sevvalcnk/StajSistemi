@{
    ViewData["Title"] = "Yönetici Paneli";
}

<div class="container mt-5">
    @* ✅ MÜHÜR: Giriş Uyarısı *@
    @if (TempData["LoginWarning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show shadow-sm border-0 rounded-4 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
                <div>
                    <h5 class="alert-heading fw-bold mb-0">Dikkat!</h5>
                    <span>@TempData["LoginWarning"]</span>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-lg border-0 rounded-4 p-5 bg-white">
        <div class="text-center mb-4">
            <i class="fas fa-user-shield fa-4x text-warning mb-3"></i>
            <h2 class="fw-bold" style="color: #2c3e50;">Sistem Yönetim Merkezi</h2>
            <p class="text-muted">Hoş geldiniz Sayın Yönetici. Tüm sistemi buradan denetleyebilirsiniz.</p>
        </div>

        <hr>

        <div class="row g-4 mt-2">
            @* --- ÖĞRENCİ YÖNETİMİ --- *@
            <div class="col-md-4">
                <a asp-controller="Student" asp-action="Index" class="btn btn-outline-primary btn-lg w-100 py-3 rounded-pill shadow-sm">
                    <i class="fas fa-users-cog me-2"></i> Tüm Öğrencileri Yönet
                </a>
            </div>

            @* --- BÖLÜM AYARLARI (İSTEDİĞİN KOD BURADA) --- *@
            <div class="col-md-4">
                <a asp-controller="Department" asp-action="Index" class="btn btn-outline-secondary btn-lg w-100 py-3 rounded-pill shadow-sm">
                    <i class="fas fa-university me-2"></i> Bölüm Ayarlarını Yapılandır
                </a>
            </div>

            @* --- STAJ İLANLARI (HAFTA 4 PLANI İÇİN EKLEDİM) --- *@
            <div class="col-md-4">
                <a asp-controller="Internship" asp-action="Index" class="btn btn-outline-success btn-lg w-100 py-3 rounded-pill shadow-sm">
                    <i class="fas fa-briefcase me-2"></i> Staj İlanlarını Yönet
                </a>
            </div>
        </div>

        @* Alt kısma bir çıkış butonu da ekleyelim, tam profesyonel olsun *@
        <div class="text-center mt-5">
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-danger btn-sm px-4 rounded-pill">
                    <i class="fas fa-sign-out-alt me-1"></i> Güvenli Çıkış Yap
                </button>
            </form>
        </div>
    </div>
</div>