@model IEnumerable<StajSistemi.DTOs.StudentDto>

@{
    ViewData["Title"] = "Siber Arşiv";
}

<div class="container mt-4 techNode-fade-in">
    <div class="card shadow-lg border-0 rounded-4 p-4 bg-white">

        @* --- 🏛️ BAŞLIK VE GERİ DÖNÜŞ --- *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-secondary"><i class="fas fa-archive me-2"></i> Arşivlenmiş Öğrenciler</h2>
            <a asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">
                <i class="fas fa-arrow-left me-2"></i> Aktif Listeye Dön
            </a>
        </div>

        @* --- 🛡️ 🚀 AKILLI ARŞİV FİLTRELEME (GELİŞTİRİLDİ) --- *@
        <div class="card bg-light border-0 rounded-4 mb-4 shadow-sm">
            <div class="card-body p-3">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-muted">Eğitim Düzeyi</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-0"><i class="fas fa-graduation-cap text-primary"></i></span>
                            <select id="EducationLevelDropdown" class="form-select border-0 shadow-none">
                                <option value="Hepsi">Hepsi</option>
                                <option value="Lisans">Lisans (4 Yıllık)</option>
                                <option value="Önlisans">Ön Lisans (2 Yıllık)</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label small fw-bold text-muted">Bölüm Bazlı Arşiv</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-0"><i class="fas fa-university text-primary"></i></span>
                            <select id="DepartmentIdDropdown" name="departmentId" class="form-select border-0 shadow-none" asp-items="ViewBag.Departments">
                                <option value="">-- Bölüm Seçiniz --</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-secondary w-100 rounded-pill fw-bold shadow-sm">
                            <i class="fas fa-filter me-1"></i> Arşivi Süz
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @* --- 📊 ARŞİV TABLOSU --- *@
        <div class="table-responsive">
            <table class="table table-hover align-middle text-center">
                <thead class="table-light">
                    <tr>
                        <th>Öğrenci Bilgisi</th>
                        <th>Bölüm</th>
                        <th>GPA</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@item.FullName</div>
                                    <small class="text-muted">No: @item.StudentNo</small>
                                </td>
                                <td>@item.DepartmentName</td>
                                <td>
                                    <span class="badge bg-info text-dark">
                                        @(item.GPA.HasValue ? item.GPA.Value.ToString("0.00") : "0.00")
                                    </span>
                                </td>
                                <td>
                                    @* 🔄 GERİ YÜKLEME MÜHÜRÜ *@
                                    <form asp-action="Restore" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success btn-sm rounded-pill px-3"
                                                onclick="return confirm('Bu öğrenci ana listeye geri dönsün mü?')">
                                            <i class="fas fa-undo me-1"></i> Geri Yükle
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-muted py-4">Arşivde kayıtlı öğrenci bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* 🛡️ 🚀 AKILLI DROPDOWN MOTORU (AJAX) *@
@section Scripts {
    <script>
        $(document).ready(function () {
            $('#EducationLevelDropdown').change(function () {
                var level = $(this).val();
                var departmentSelect = $('#DepartmentIdDropdown');

                departmentSelect.empty();
                departmentSelect.append('<option value="">Bölümler Yükleniyor...</option>');

                $.ajax({
                    url: '/Advisor/GetDepartmentsByLevel',
                    type: 'GET',
                    data: { level: level },
                    success: function (data) {
                        departmentSelect.empty();
                        departmentSelect.append('<option value="">-- Bölüm Seçiniz --</option>');
                        $.each(data, function (i, item) {
                            departmentSelect.append('<option value="' + item.id + '">' + item.name + '</option>');
                        });
                    },
                    error: function () {
                        console.error("Arşiv bölümleri çekilirken siber bir hata oluştu.");
                    }
                });
            });
        });
    </script>
}