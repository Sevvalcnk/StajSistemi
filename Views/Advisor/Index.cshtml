@{
    ViewData["Title"] = "Danışman Paneli";
}

<div class="container mt-5 techNode-fade-in">
    @* ✅ MÜHÜR: Giriş Uyarısı *@
    @if (TempData["LoginWarning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show shadow-sm border-0 rounded-4 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-exclamation-triangle fa-2x me-3 text-warning"></i>
                <div>
                    <h5 class="alert-heading fw-bold mb-0">Oturum Bilgisi</h5>
                    <span>@TempData["LoginWarning"]</span>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-lg border-0 rounded-4 p-5 bg-white">
        <div class="text-center mb-4">
            <div class="bg-success bg-opacity-10 d-inline-block p-4 rounded-circle mb-3">
                <i class="fas fa-chalkboard-teacher fa-4x text-success"></i>
            </div>
            <h2 class="fw-bold" style="color: #2c3e50;">Danışman (Öğretim Elemanı) Paneli</h2>
            <p class="text-muted">Öğrenci başvurularını değerlendirebilir, kariyer dosyalarını inceleyebilir ve süreci yönetebilirsiniz.</p>
        </div>

        <div class="row g-3 mt-4">
            @* ✅ MÜHÜR: Staj Başvuruları Linki *@
            <div class="col-md-4">
                <a asp-controller="Internship" asp-for="Applications" class="btn btn-success w-100 rounded-pill py-3 fw-bold shadow-sm h-100 d-flex align-items-center justify-content-center">
                    <i class="fas fa-file-signature me-2"></i> Staj Başvuruları
                </a>
            </div>

            @* ✅ MÜHÜR: Öğrenci Listesi Linki *@
            <div class="col-md-4">
                <a asp-controller="Student" asp-action="Index" class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow-sm h-100 d-flex align-items-center justify-content-center">
                    <i class="fas fa-users me-2"></i> Öğrenci Listesi
                </a>
            </div>

            @* ✅ YENİ MÜHÜR: Kariyer Havuzu & Belgeler *@
            <div class="col-md-4">
                <a asp-controller="Student" asp-action="Index" class="btn btn-dark w-100 rounded-pill py-3 fw-bold shadow-sm h-100 d-flex align-items-center justify-content-center">
                    <i class="fas fa-id-card-alt me-2 text-info"></i> Kariyer Havuzu
                </a>
            </div>
        </div>

        <div class="mt-5 p-4 bg-light rounded-4 border-start border-5 border-success small">
            <h6 class="fw-bold mb-1"><i class="fas fa-info-circle me-1 text-success"></i> Danışman Notu:</h6>
            <p class="text-muted mb-0">Öğrenci listesi üzerinden öğrencilerin yüklediği güncel CV ve sertifikalara "Kariyer Dosyası" butonu ile ulaşabilirsiniz.</p>
        </div>
    </div>
</div>