@model List<StajSistemi.Models.InternshipApplication>

<div class="container py-4">
    <div class="glass-card p-4 shadow-lg border-0 rounded-4 bg-white">
        <h4 class="fw-bold mb-4"><i class="fas fa-tasks text-primary me-2"></i>Bekleyen Staj Başvuruları</h4>

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Öğrenci</th>
                            <th>Şirket</th>
                            <th>Başvuru Tarihi</th>
                            <th class="text-center">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@app.AppUser?.FirstName @app.AppUser?.LastName</div>
                                </td>
                                <td>@app.Internship?.CompanyName</td>
                                <td>@app.ApplicationDate.ToShortDateString()</td>
                                <td class="text-center">
                                    @* ✅ ONAY BUTONU *@
                                    <form asp-action="UpdateApplicationStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@app.Id" />
                                        <input type="hidden" name="status" value="Onaylandı" />
                                        <button type="submit" class="btn btn-sm btn-success rounded-pill px-3 me-2">
                                            <i class="fas fa-check me-1"></i> Onayla
                                        </button>
                                    </form>

                                    @* ❌ RED BUTONU *@
                                    <form asp-action="UpdateApplicationStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@app.Id" />
                                        <input type="hidden" name="status" value="Reddedildi" />
                                        <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3">
                                            <i class="fas fa-times me-1"></i> Reddet
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 opacity-50">
                <i class="fas fa-check-double fa-3x mb-3 text-success"></i>
                <p>Bekleyen başvuru kalmadı kardaşım! Her şey kontrol altında. 🥂</p>
            </div>
        }
    </div>
</div>