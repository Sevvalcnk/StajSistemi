@model StajSistemi.DTOs.StudentDto

@{
    ViewData["Title"] = "Öğrenci Kariyer Dosyası";
}

<div class="container py-4 techNode-fade-in">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        @* --- 🛡️ ÜST BANT: KURUMSAL GÖRÜNÜM --- *@
        <div class="card-header bg-dark p-4 border-0 d-flex justify-content-between align-items-center">
            <h4 class="fw-bold text-white mb-0">
                <i class="fas fa-user-shield me-2 text-info"></i>Öğrenci Kariyer Analizi
            </h4>
            <a href="javascript:history.back()" class="btn btn-outline-light btn-sm rounded-pill px-3">
                <i class="fas fa-arrow-left me-1"></i> Geri Dön
            </a>
        </div>

        <div class="card-body p-5 bg-white">
            <div class="row">
                @* --- 👤 SOL SÜTUN: KİMLİK VE İLETİŞİM --- *@
                <div class="col-md-4 text-center border-end">
                    <img src="https://ui-avatars.com/api/?name=@Model.Name+@Model.Surname&size=150&background=2c3e50&color=fff"
                         class="rounded-circle mb-3 shadow-sm border border-4 border-white" alt="Profil">
                    <h3 class="fw-bold text-dark">@Model.Name @Model.Surname</h3>
                    <span class="badge bg-primary rounded-pill px-3 py-2 mb-3">@Model.DepartmentName</span>

                    <div class="text-start mt-4 px-3">
                        <div class="mb-3">
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.65rem;">Öğrenci No</small>
                            <span class="text-dark fw-bold">@Model.StudentNo</span>
                        </div>
                        <div class="mb-3 border-top pt-2">
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.65rem;">E-posta</small>
                            <span class="text-dark">@Model.Email</span>
                        </div>
                        <div class="mb-3 border-top pt-2">
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.65rem;">Telefon</small>
                            <span class="text-dark">@(Model.PhoneNumber ?? "Girilmemiş")</span>
                        </div>
                    </div>
                </div>

                @* --- 🚀 SAĞ SÜTUN: AKADEMİK VE BELGELER --- *@
                <div class="col-md-8 ps-md-5">
                    <h5 class="fw-bold text-dark mb-3"><i class="fas fa-chart-line me-2 text-primary"></i>Akademik Performans</h5>
                    <div class="progress mb-4" style="height: 25px; border-radius: 15px;">
                        @{
                            var barColor = Model.GPA >= 3.0 ? "bg-success" : (Model.GPA >= 2.0 ? "bg-info" : "bg-warning");
                        }
                        <div class="progress-bar @barColor progress-bar-striped progress-bar-animated fw-bold"
                             style="width: @(Model.GPA * 25)%">
                            GPA: @Model.GPA / 4.0
                        </div>
                    </div>

                    <h5 class="fw-bold text-dark mb-3 mt-4"><i class="fas fa-lightbulb me-2 text-warning"></i>Yetenekler & Uzmanlıklar</h5>
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        @if (!string.IsNullOrEmpty(Model.PersonalSkills))
                        {
                            foreach (var skill in Model.PersonalSkills.Split(','))
                            {
                                <span class="badge bg-light text-dark border rounded-pill px-3 py-2">@skill.Trim()</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted small italic">Öğrenci henüz yetenek bilgisi girmedi.</span>
                        }
                    </div>

                    <h5 class="fw-bold text-dark mb-3 mt-4"><i class="fas fa-folder-open me-2 text-danger"></i>Mühürlü Belgeler</h5>
                    <div class="row g-3">
                        @* CV İNCELEME BUTONU *@
                        <div class="col-md-6">
                            @if (!string.IsNullOrEmpty(Model.CVPath))
                            {
                                <a href="@Model.CVPath" target="_blank" class="btn btn-danger w-100 rounded-pill shadow-sm py-2 fw-bold">
                                    <i class="fas fa-file-pdf me-2"></i>CV'yi Görüntüle
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100 rounded-pill disabled py-2 opacity-50">CV Yüklenmemiş</button>
                            }
                        </div>

                        @* SERTİFİKA LİSTESİ (ÇOKLU SEÇİM DESTEKLİ) *@
                        <div class="col-md-6">
                            @if (!string.IsNullOrEmpty(Model.CertificatePath))
                            {
                                var certs = Model.CertificatePath.Split(';');
                                <div class="dropdown">
                                    <button class="btn btn-primary w-100 rounded-pill dropdown-toggle shadow-sm py-2 fw-bold" type="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-award me-2"></i>Sertifikalar (@certs.Length)
                                    </button>
                                    <ul class="dropdown-menu w-100 rounded-4 shadow border-0 mt-2">
                                        @{
                                            int i = 1;
                                        }
                                        @foreach (var cert in certs)
                                        {
                                            <li><a class="dropdown-item py-2" href="@cert" download><i class="fas fa-download me-2 text-muted"></i> Sertifika @i</a></li>
                                            i++;
                                        }
                                    </ul>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100 rounded-pill disabled py-2 opacity-50">Sertifika Yok</button>
                            }
                        </div>
                    </div>

                    @* EĞİTİM ÖZETİ *@
                    <div class="mt-5 p-4 bg-light rounded-4 border-start border-5 border-info">
                        <h6 class="fw-bold mb-1">Eğitim Özeti:</h6>
                        <p class="mb-0 small">@(Model.EducationSummary ?? "Belirtilmemiş")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>