@model StajSistemi.DTOs.StudentDto

@{
    ViewData["Title"] = "Öğrenci Detay Profili";
}

<div class="container py-5">
    <div class="glass-card p-5 shadow-lg border-0 rounded-4 bg-white mx-auto" style="max-width: 900px;">

        @* --- PROFİL ÜST KISIM --- *@
        <div class="text-center mb-5">
            <div class="mb-3">
                <img src="https://ui-avatars.com/api/?name=@(Model.Name)+@(Model.Surname)&background=2c3e50&color=fff&size=128"
                     class="rounded-circle shadow-sm border border-4 border-white" style="width: 120px;" alt="Profil">
            </div>
            <h2 class="fw-bold text-dark mb-1">@Model.Name @Model.Surname</h2>
            <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2 border">Öğrenci No: @(Model.StudentNo ?? "247018019")</span>
        </div>

        <div class="row g-4">
            @* --- AKADEMİK BİLGİ --- *@
            <div class="col-md-6">
                <div class="p-4 bg-light rounded-4 h-100">
                    <h6 class="fw-bold text-uppercase small text-muted mb-3"><i class="fas fa-graduation-cap me-2"></i>Akademik Bilgi</h6>
                    <div class="mb-2">
                        <small class="d-block text-muted">Bölüm / Program</small>
                        <span class="fw-bold text-dark">@(Model.EducationSummary ?? "İnternet ve Ağ Teknolojileri")</span>
                    </div>
                    <div class="mt-3">
                        <small class="d-block text-muted">GPA Başarı Oranı</small>
                        <div class="d-flex align-items-center gap-2">
                            <h4 class="fw-bold text-primary mb-0">@Model.GPA</h4>
                            <span class="text-muted small">/ 4.0</span>
                        </div>
                    </div>
                </div>
            </div>

            @* --- YETENEKLER --- *@
            <div class="col-md-6">
                <div class="p-4 bg-light rounded-4 h-100">
                    <h6 class="fw-bold text-uppercase small text-muted mb-3"><i class="fas fa-tools me-2"></i>Yetenekler & Beceriler</h6>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        @if (!string.IsNullOrEmpty(Model.PersonalSkills))
                        {
                            foreach (var skill in Model.PersonalSkills.Split(','))
                            {
                                <span class="badge bg-white text-dark border rounded-pill fw-normal px-3 py-2 shadow-sm">@skill.Trim()</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted small italic">Henüz yetenek girişi yapılmamış.</span>
                        }
                    </div>
                </div>
            </div>

            @* --- 🛡️ ÖĞRENCİ BELGELERİ VE STAJ DEFTERİ --- *@
            <div class="col-12">
                <div class="p-4 border border-primary border-opacity-25 rounded-4 bg-light bg-opacity-10">
                    <h6 class="fw-bold text-uppercase small text-muted mb-4"><i class="fas fa-folder-open me-2 text-primary"></i>Öğrenci Belgeleri & Takip</h6>
                    <div class="row g-3">
                        @* CV Sütunu *@
                        <div class="col-md-4">
                            @if (!string.IsNullOrEmpty(Model.CVPath))
                            {
                                <a href="@Model.CVPath" target="_blank" class="btn btn-white border shadow-sm w-100 py-3 rounded-4 transition hover-up">
                                    <div class="d-flex align-items-center px-2">
                                        <i class="fas fa-file-pdf fa-2x text-danger me-3"></i>
                                        <div class="text-start">
                                            <div class="fw-bold text-dark small">Özgeçmiş (CV)</div>
                                            <small class="text-muted">Görüntüle</small>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>

                        @* Sertifika Sütunu *@
                        <div class="col-md-4">
                            @if (!string.IsNullOrEmpty(Model.CertificatePath))
                            {
                                <a href="@Model.CertificatePath" target="_blank" class="btn btn-white border shadow-sm w-100 py-3 rounded-4 transition hover-up">
                                    <div class="d-flex align-items-center px-2">
                                        <i class="fas fa-certificate fa-2x text-warning me-3"></i>
                                        <div class="text-start">
                                            <div class="fw-bold text-dark small">Sertifika</div>
                                            <small class="text-muted">Görüntüle</small>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>

                        @* ✅ HAFTA 7 MÜHÜRÜ: STAJ DEFTERİ BUTONU *@
                        <div class="col-md-4">
                            <a asp-controller="DailyReport" asp-action="Index" asp-route-studentId="@Model.Id" class="btn btn-white border border-primary shadow-sm w-100 py-3 rounded-4 transition hover-up">
                                <div class="d-flex align-items-center px-2">
                                    <i class="fas fa-book-open fa-2x text-primary me-3"></i>
                                    <div class="text-start">
                                        <div class="fw-bold text-dark small">Staj Defteri</div>
                                        <small class="text-info">Raporları İncele</small>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            @* --- İLETİŞİM --- *@
            <div class="col-12">
                <div class="p-4 border rounded-4">
                    <h6 class="fw-bold text-uppercase small text-muted mb-3"><i class="fas fa-envelope me-2"></i>İletişim Bilgileri</h6>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <small class="text-muted">E-Posta Adresi</small>
                            <p class="fw-bold text-dark">@Model.Email</p>
                        </div>
                        <div class="col-md-6 mb-2">
                            <small class="text-muted">Telefon</small>
                            <p class="fw-bold text-dark">@(Model.PhoneNumber ?? "Belirtilmemiş")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* --- ALT BUTONLAR --- *@
        <div class="d-flex justify-content-between mt-5 pt-3 border-top">
            <a href="javascript:history.back()" class="btn btn-light rounded-pill px-4">
                <i class="fas fa-arrow-left me-2"></i> Geri Dön
            </a>

            <a asp-controller="Chat"
               asp-action="Index"
               asp-route-receiverId="@Model.Id"
               class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="fas fa-comment-dots me-2"></i> Öğrenciye Mesaj At
            </a>
        </div>
    </div>
</div>

<style>
    .hover-up:hover {
        transform: translateY(-3px);
        transition: 0.3s;
    }

    .bg-soft-primary {
        background-color: rgba(13, 110, 253, 0.08);
    }
</style>