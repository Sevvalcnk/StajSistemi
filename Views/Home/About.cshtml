@model StajSistemi.DTOs.StudentDto

@{
    ViewData["Title"] = "Hakkımızda";
}

<style>
    /* ✅ Sayfa Tasarım Mühürleri */
    body {
        background-color: #f4f7f6;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;
    }

    .profile-avatar {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border: 4px solid white;
    }

    .feature-box {
        transition: 0.3s;
        border: 1px solid #eee;
        background-color: #ffffff;
    }

        .feature-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            border-color: #3498db;
        }

    .tech-stack-badge {
        background-color: #eef2f7;
        color: #2c3e50;
        font-weight: 600;
        font-size: 0.85rem;
    }
</style>

<div class="container mt-4 pb-5">
    <div class="row">
        @* --- 👤 SOL TARAF: KULLANICI KÜNYESİ --- *@
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm text-center p-4 h-100 bg-white">
                <div class="mb-3">
                    <img src="https://ui-avatars.com/api/?name=@(Model?.Name ?? "Misafir")+@(Model?.Surname)&background=2c3e50&color=fff&size=128"
                         class="rounded-circle profile-avatar shadow-sm" alt="Profil">
                </div>
                <h5 class="fw-bold mb-0">@Model?.Name @Model?.Surname</h5>
                <p class="text-muted small">@Model?.Email</p>

                <hr class="my-4 opacity-25">

                <div class="text-start px-2">
                    <p class="small text-muted mb-3 text-uppercase fw-bold">Sistem Entegrasyonu</p>
                    <div class="d-flex align-items-center mb-2">
                        <i class="fas fa-database text-success me-2"></i>
                        <span class="small">SQL Server Bağlantısı: **Aktif**</span>
                    </div>
                    <div class="d-flex align-items-center mb-2">
                        <i class="fas fa-user-shield text-primary me-2"></i>
                        <span class="small">Identity Yetkilendirme: **Aktif**</span>
                    </div>
                    <div class="d-flex align-items-center mb-2">
                        <i class="fas fa-server text-info me-2"></i>
                        <span class="small">API Entegrasyon Modülü: **Hazır**</span>
                    </div>
                </div>

                <a asp-controller="StudentPanel" asp-action="Index" class="btn btn-primary rounded-pill w-100 mt-4 shadow-sm fw-bold">
                    <i class="fas fa-arrow-left me-2"></i> Panele Dön
                </a>
            </div>
        </div>

        @* --- 📖 SAĞ TARAF: SİSTEM DETAYLARI --- *@
        <div class="col-lg-8 mb-4">
            <div class="card p-5 bg-white shadow-sm h-100">
                <div class="text-center mb-5">
                    <i class="fas fa-university fa-4x text-primary mb-3"></i>
                    <h2 class="fw-bold text-dark">Staj Takip Sistemi <span class="badge bg-primary fs-6 align-middle">v1.0</span></h2>
                    <p class="text-muted">Geleceğin profesyonellerini dijital dünyada mühürleyen yönetim portalı.</p>
                </div>

                <div class="row g-4">
                    <div class="col-12">
                        <h5 class="fw-bold border-bottom pb-2 mb-3"><i class="fas fa-eye text-primary me-2"></i>Sistem Vizyonu</h5>
                        <p class="text-muted">
                            Bu platform, üniversite staj süreçlerindeki kağıt israfını bitirmek, öğrencilerin başvurularını
                            tek tıkla mühürlemesini sağlamak ve danışman onay süreçlerini tamamen şeffaf bir dijital
                            ortama taşımak amacıyla **temiz kod (clean code)** prensipleriyle geliştirilmiştir.
                        </p>
                    </div>

                    <div class="col-md-6">
                        <div class="feature-box p-4 rounded-4 h-100">
                            <i class="fas fa-layer-group text-success fa-2x mb-3"></i>
                            <h6 class="fw-bold">N-Tier Architecture</h6>
                            <p class="small text-muted mb-0">
                                Proje; **Data**, **Business** ve **Web** katmanları olarak ayrıştırılarak, modüler ve
                                test edilebilir bir yapıya büründürülmüştür.
                            </p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="feature-box p-4 rounded-4 h-100">
                            <i class="fas fa-shield-virus text-info fa-2x mb-3"></i>
                            <h6 class="fw-bold">Veri Güvenliği & DTO</h6>
                            <p class="small text-muted mb-0">
                                **Data Transfer Object** kullanımı ile hassas veriler maskelenir ve sunucu ile
                                istemci arasındaki trafik mühürlenerek korunur.
                            </p>
                        </div>
                    </div>

                    <div class="col-md-12 mt-4">
                        <div class="p-4 rounded-4 border-start border-5 border-primary bg-light">
                            <h6 class="fw-bold mb-3"><i class="fas fa-code me-2"></i> Teknik Altyapı ve Kütüphaneler</h6>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge tech-stack-badge p-2">ASP.NET Core 8.0</span>
                                <span class="badge tech-stack-badge p-2">Entity Framework Core</span>
                                <span class="badge tech-stack-badge p-2">AutoMapper</span>
                                <span class="badge tech-stack-badge p-2">Fluent Validation</span>
                                <span class="badge tech-stack-badge p-2">Repository Pattern</span>
                                <span class="badge tech-stack-badge p-2">UnitOfWork</span>
                                <span class="badge tech-stack-badge p-2">Bootstrap 5</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>