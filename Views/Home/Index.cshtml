@model List<StajSistemi.Models.Internship>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staj Sistemi - Hoş Geldiniz</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        /* ✅ Senin Tasarım Mühürlerin Aynen Korundu */
        body {
            background: linear-gradient(rgba(44, 62, 80, 0.8), rgba(44, 62, 80, 0.8)), url('https://images.unsplash.com/photo-1434030216411-0b793f4b4173?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
            color: white;
        }

        .main-wrapper {
            width: 100%;
            max-width: 1200px;
            margin: auto;
            padding: 50px 20px;
        }

        .hero-section {
            text-align: center;
            margin-bottom: 60px;
        }

        .actor-card {
            background: white;
            border: none;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            transition: all 0.3s ease;
            color: #333;
            height: 100%;
            overflow: hidden;
        }

            .actor-card:hover {
                transform: translateY(-15px);
            }

        .strip {
            padding: 15px;
            color: white;
            font-weight: bold;
            font-size: 1.1rem;
            text-align: center;
        }

        .strip-student {
            background-color: #5b8bc3;
        }

        .strip-advisor {
            background-color: #6da59c;
        }

        .strip-admin {
            background-color: #f3a656;
        }

        .btn-entry {
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            color: #2c3e50;
            font-weight: 700;
            border-radius: 12px;
            padding: 10px 20px;
            display: block;
            text-decoration: none;
            transition: 0.2s;
            margin: 10px auto;
            width: 85%;
        }

            .btn-entry:hover {
                background-color: #2c3e50;
                color: white;
            }

        .intern-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 24px;
            color: #2c3e50;
            border: none;
            transition: 0.4s;
            position: relative;
        }

            .intern-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 25px 50px rgba(0,0,0,0.4) !important;
            }

        .map-radar-link {
            color: #6c757d;
            text-decoration: none;
            padding: 4px 10px;
            border-radius: 8px;
            background: #f8f9fa;
            border: 1px solid #eee;
            transition: 0.3s;
            font-size: 0.75rem;
            font-weight: 600;
        }

            .map-radar-link:hover {
                background: #e74c3c;
                color: #fff !important;
            }

        .starred-company {
            color: #2c3e50;
            font-weight: 800;
        }

        .star-box {
            color: #f3a656;
            letter-spacing: 2px;
            font-size: 1.1rem;
        }

        .carousel-control-prev {
            left: -80px;
            width: 50px;
        }

        .carousel-control-next {
            right: -80px;
            width: 50px;
        }

        .carousel-icon-box {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            padding: 15px;
            transition: 0.3s;
        }
    </style>
</head>
<body>

    <div class="main-wrapper">
        <div class="hero-section py-4">
            <i class="fas fa-graduation-cap fa-5x mb-4 text-white"></i>
            <h1 class="display-4 mb-3">Staj Süreçlerini <span style="color: #f3a656;">Mühürleyin!</span></h1>
            <p class="lead opacity-75 fs-4 mx-auto" style="max-width: 800px;">Dijital staj takip sistemi ile kariyerinize profesyonel bir başlangıç yapın.</p>
        </div>

        @* --- 🛡️ 3'LÜ PORTAL KARTLARI --- *@
        <div class="row g-4 justify-content-center mb-5">
            <div class="col-md-4">
                <div class="card actor-card">
                    <div class="strip strip-student">ÖĞRENCİ PORTALI</div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-user-graduate fa-3x mb-3" style="color: #5b8bc3;"></i>
                        <p class="small text-muted mb-4">İlanlara başvur ve sonuçlarını takip et.</p>
                        <a asp-controller="Account" asp-action="Login" asp-route-role="Student" class="btn btn-entry shadow-sm">Giriş Yap</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card actor-card">
                    <div class="strip strip-advisor">DANIŞMAN PORTALI</div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-chalkboard-teacher fa-3x mb-3" style="color: #6da59c;"></i>
                        <p class="small text-muted mb-4">Başvuruları değerlendir ve mühürle.</p>
                        <a asp-controller="Account" asp-action="Login" asp-route-role="Advisor" class="btn btn-entry shadow-sm">Yetkili Girişi</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card actor-card">
                    <div class="strip strip-admin">SİSTEM YÖNETİCİSİ</div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-user-shield fa-3x mb-3" style="color: #f3a656;"></i>
                        <p class="small text-muted mb-4">Bölümleri ve sistem ayarlarını yönet.</p>
                        <a asp-controller="Account" asp-action="Login" asp-route-role="Admin" class="btn btn-entry shadow-sm">Yönetici Paneli</a>
                    </div>
                </div>
            </div>
        </div>

        @* --- 🎡 KAYDIRILABİLİR İLANLAR --- *@
        <div class="mt-5 pt-4 position-relative">
            <h3 class="text-center mb-5 fw-bold"><i class="fas fa-fire text-danger me-2"></i>Günün Öne Çıkan İlanları</h3>

            <div id="internshipCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @if (Model != null && Model.Any())
                    {
                        for (int i = 0; i < Model.Count; i += 3)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <div class="row g-4">
                                    @foreach (var ilan in Model.Skip(i).Take(3))
                                    {
                                        <div class="col-md-4">
                                            <div class="card intern-card h-100 shadow-lg border-0">
                                                <div class="card-body p-4">
                                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                                        <span class="badge bg-light text-primary rounded-pill small border" style="font-size: 0.65rem;">
                                                            @(ilan.Department?.DepartmentName ?? "Genel")
                                                        </span>

                                                        @* ✅ KRİTİK DÜZELTME: "Ordu" (Konum) yazısına tıklayınca doğrudan Google Maps açılır *@
                                                        <a href="https://www.google.com/maps/search/?api=1&query=@(ilan.CompanyName)+@(ilan.City?.Name ?? ilan.CityName)" target="_blank" class="map-radar-link">
                                                            <i class="fas fa-map-marker-alt"></i> @(ilan.City?.Name ?? ilan.CityName ?? "Konum")
                                                        </a>
                                                    </div>

                                                    <h5 class="fw-bold mb-2 starred-company">
                                                        @{
                                                            string compName = ilan.CompanyName ?? "Şirket";
                                                            string masked = compName.Length > 3 ? compName.Substring(0, 3) : compName;
                                                        }
                                                        @masked<span class="star-box">****</span>
                                                    </h5>

                                                    <p class="small text-secondary mb-4">
                                                        @{
                                                            string d = ilan.Description ?? "Detaylar için giriş yapınız.";
                                                            string shortDesc = d.Length > 60 ? d.Substring(0, 60) + "..." : d;
                                                        }
                                                        @shortDesc
                                                    </p>

                                                    <div class="d-grid mt-auto">
                                                        @* ✅ İlanın detaylarını görmek için başlığı veya bu butonu kullanabilirsin *@
                                                        <a asp-controller="Internship" asp-action="Details" asp-route-id="@ilan.Id" class="btn btn-sm btn-dark rounded-pill py-2 fw-bold">
                                                            Giriş Yap ve Gör <i class="fas fa-lock ms-1" style="font-size: 0.7rem;"></i>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-center opacity-50">Henüz yayınlanmış bir ilan bulunmuyor.</p>
                    }
                </div>

                @if (Model != null && Model.Count > 3)
                {
                    <button class="carousel-control-prev" type="button" data-bs-target="#internshipCarousel" data-bs-slide="prev">
                        <i class="fas fa-chevron-left carousel-icon-box text-white fs-4"></i>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#internshipCarousel" data-bs-slide="next">
                        <i class="fas fa-chevron-right carousel-icon-box text-white fs-4"></i>
                    </button>
                }
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
</body>
</html>