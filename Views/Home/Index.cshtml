@{
    ViewData["Title"] = "Staj Portalı";
}

@* İkonlar için Font Awesome kütüphanesi *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container text-center py-5 animate__animated animate__fadeIn">
    <div class="mb-5">
        <div class="display-4 text-primary mb-3">
            <i class="fas fa-graduation-cap"></i>
        </div>
        <h1 class="fw-bold" style="color: #2c3e50;">Akıllı Staj Başvuru ve Süreç Yönetimi</h1>
        <p class="text-muted fs-5">Lütfen devam etmek için sistemdeki rolünüzü seçiniz.</p>
    </div>

    <div class="row g-4 mt-2 justify-content-center">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm portal-card rounded-4 border-0">
                <div class="card-body p-5">
                    <div class="mb-4 text-primary">
                        <i class="fas fa-user-graduate fa-4x"></i>
                    </div>
                    <h3 class="fw-bold">Öğrenci</h3>
                    <p class="text-muted small">Başvuru yap, staj dosyalarını yükle ve sonuçlarını anlık takip et.</p>
                    <a href="/Account/Login?role=Öğrenci" class="btn btn-primary btn-portal w-100 mt-3 shadow">Giriş Yap</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm portal-card rounded-4 border-0">
                <div class="card-body p-5">
                    <div class="mb-4" style="color: #6da59c;">
                        <i class="fas fa-chalkboard-teacher fa-4x"></i>
                    </div>
                    <h3 class="fw-bold">Danışman</h3>
                    <p class="text-muted small">Öğrenci başvurularını değerlendir, evrakları onayla ve süreci yönet.</p>
                    <a href="/Account/Login?role=Danışman" class="btn btn-success btn-portal w-100 mt-3 shadow" style="background-color: #6da59c; border: none;">Giriş Yap</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm portal-card rounded-4 border-0">
                <div class="card-body p-5">
                    <div class="mb-4 text-warning">
                        <i class="fas fa-user-shield fa-4x"></i>
                    </div>
                    <h3 class="fw-bold">Yönetici</h3>
                    <p class="text-muted small">Sistem ayarlarını yapılandır, kullanıcıları ve bölümleri denetle.</p>
                    <a href="/Account/Login?role=Yönetici" class="btn btn-warning btn-portal w-100 mt-3 shadow text-white">Giriş Yap</a>
                </div>
            </div>
        </div>
    </div>
</div>