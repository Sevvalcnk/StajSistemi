@using StajSistemi.Models
@model IEnumerable<StajSistemi.Models.Internship>

@{
    ViewData["Title"] = "Staj İlanları";
    var appliedIds = ViewBag.AppliedIds as List<int> ?? new List<int>();
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staj Sistemi - Hoş Geldiniz</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            background: linear-gradient(rgba(44, 62, 80, 0.85), rgba(44, 62, 80, 0.85)), url('https://images.unsplash.com/photo-1434030216411-0b793f4b4173?auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            margin: 0;
            color: white;
        }

        .main-wrapper {
            width: 100%;
            max-width: 1200px;
            margin: auto;
            padding: 50px 20px;
        }

        .actor-card {
            background: white;
            border: none;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            transition: all 0.3s ease;
            color: #333;
            height: 100%;
            overflow: hidden;
        }

            .actor-card:hover {
                transform: translateY(-15px);
            }

        .strip {
            padding: 15px;
            color: white;
            font-weight: bold;
            font-size: 1.1rem;
            text-align: center;
        }

        .strip-student {
            background-color: #5b8bc3;
        }

        .strip-advisor {
            background-color: #6da59c;
        }

        .strip-admin {
            background-color: #f3a656;
        }

        .btn-entry {
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            color: #2c3e50;
            font-weight: 700;
            border-radius: 12px;
            padding: 10px 20px;
            display: block;
            text-decoration: none;
            margin: 10px auto;
            width: 85%;
            text-align: center;
        }

        .intern-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 24px;
            color: #2c3e50;
            border: none;
            transition: 0.4s;
            display: flex;
            flex-direction: column;
        }

        .map-radar-link {
            color: #6c757d;
            text-decoration: none;
            padding: 4px 10px;
            border-radius: 8px;
            background: #f8f9fa;
            border: 1px solid #eee;
            font-size: 0.75rem;
            font-weight: 600;
            white-space: nowrap;
        }

        .starred-company {
            color: #2c3e50;
            font-weight: 800;
        }

        .star-box {
            color: #f3a656;
            letter-spacing: 2px;
        }

        .carousel-control-prev {
            left: -80px;
            width: 50px;
        }

        .carousel-control-next {
            right: -80px;
            width: 50px;
        }

        .carousel-icon-box {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            padding: 15px;
        }
    </style>
</head>
<body>

    <div class="main-wrapper">
        <div class="hero-section text-center py-4 mb-5">
            <i class="fas fa-graduation-cap fa-5x mb-4 text-white"></i>
            <h1 class="display-4 mb-3" style="font-weight: 800;">Staj Süreçlerini <span style="color: #f3a656;">Mühürleyin!</span></h1>
            <p class="fs-5 opacity-75">Geleceğini liyakatle ve profesyonelce yönetmeye başla.</p>
        </div>

        <div class="row g-4 justify-content-center mb-5">
            <div class="col-md-4">
                <div class="card actor-card">
                    <div class="strip strip-student">ÖĞRENCİ PORTALI</div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-user-graduate fa-3x mb-3" style="color: #5b8bc3;"></i>
                        <a href="/Account/Login?role=Student" class="btn btn-entry">Giriş Yap</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card actor-card">
                    <div class="strip strip-advisor">DANIŞMAN PORTALI</div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-chalkboard-teacher fa-3x mb-3" style="color: #6da59c;"></i>
                        <a href="/Account/Login?role=Advisor" class="btn btn-entry">Yetkili Girişi</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card actor-card">
                    <div class="strip strip-admin">SİSTEM YÖNETİCİSİ</div>
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-user-shield fa-3x mb-3" style="color: #f3a656;"></i>
                        <a href="/Account/Login?role=Admin" class="btn btn-entry">Yönetici Paneli</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 pt-4 position-relative">
            <h3 class="text-center mb-5 fw-bold"><i class="fas fa-fire text-danger me-2"></i>Günün Öne Çıkan İlanları</h3>

            <div id="internshipCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @if (Model != null && Model.Any())
                    {
                        var internshipList = Model.ToList();
                        for (int i = 0; i < internshipList.Count; i += 3)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <div class="row g-4">
                                    @foreach (var ilan in internshipList.Skip(i).Take(3))
                                    {
                                        <div class="col-md-4">
                                            <div class="card intern-card h-100 shadow-lg border-0">
                                                <div class="card-body p-4 d-flex flex-column">
                                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                                        <div class="d-flex flex-wrap" style="max-width: 65%;">
                                                            @* ✅ KRİTİK DÜZELTME: Bölüm İsimlerini Pırlanta Gibi Getiriyoruz *@
                                                            @if (ilan.InternshipDepartments != null && ilan.InternshipDepartments.Any())
                                                            {
                                                                foreach (var deptMap in ilan.InternshipDepartments)
                                                                {
                                                                    <span class="badge bg-light text-primary rounded-pill border me-1 mb-1 shadow-sm" style="font-size: 0.65rem; font-weight: 700;">
                                                                        <i class="fas fa-graduation-cap me-1" style="font-size: 0.6rem;"></i>
                                                                        @(deptMap.Department?.DepartmentName ?? "Bölüm")
                                                                    </span>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-light text-muted rounded-pill border me-1 mb-1" style="font-size: 0.65rem;">Genel</span>
                                                            }
                                                        </div>

                                                        @* ✅ MÜHÜR: Google Maps Linki Onarıldı *@
                                                        <a href="https://www.google.com/maps/search/?api=1&query=@(Uri.EscapeDataString(ilan.CompanyName + " " + (ilan.City?.Name ?? "")))" target="_blank" class="map-radar-link shadow-sm">
                                                            <i class="fas fa-map-marker-alt text-danger me-1"></i> @(ilan.City?.Name ?? "Konum")
                                                        </a>
                                                    </div>

                                                    <h5 class="fw-bold mb-2 starred-company">
                                                        @{
                                                            string compName = ilan.CompanyName ?? "Şirket";
                                                            string masked = compName.Length > 3 ? compName.Substring(0, 3) : compName;
                                                        }
                                                        @masked<span class="star-box">****</span>
                                                    </h5>

                                                    <p class="small text-secondary mb-4 flex-grow-1">
                                                        @(ilan.Description?.Length > 85 ? ilan.Description.Substring(0, 85) + "..." : ilan.Description)
                                                    </p>

                                                    <div class="d-grid mt-auto">
                                                        <a href="/Internship/Details/@ilan.Id" class="btn btn-sm btn-dark rounded-pill py-2 fw-bold shadow-sm">
                                                            Giriş Yap ve Gör <i class="fas fa-lock ms-1" style="font-size: 0.7rem;"></i>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <p class="text-white opacity-75">Henüz öne çıkan bir ilan bulunmuyor.</p>
                        </div>
                    }
                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#internshipCarousel" data-bs-slide="prev">
                    <span class="carousel-icon-box shadow-lg"><i class="fas fa-chevron-left text-white"></i></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#internshipCarousel" data-bs-slide="next">
                    <span class="carousel-icon-box shadow-lg"><i class="fas fa-chevron-right text-white"></i></span>
                </button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
</body>
</html>