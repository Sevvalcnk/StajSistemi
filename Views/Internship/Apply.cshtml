@model StajSistemi.Models.Internship

@{
    ViewData["Title"] = "Staj Başvurusu";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="container py-5 techNode-fade-in">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                @* ✅ ÜST PANEL: Dinamik Renk Mühürü *@
                <div class="card-header text-white text-center py-4" style="background: linear-gradient(135deg, #11998e, #38ef7d) !important;">
                    <i class="fas fa-file-signature fa-3x mb-3"></i>
                    <h3 class="fw-bold mb-0">Staj Başvurusu</h3>
                    <p class="small mb-0 opacity-75">@Model.CompanyName - @Model.Name</p>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">

                    @* 🚩 Hata Mesajı Radarı *@
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger border-0 shadow-sm small mb-4 techNode-shake">
                            <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
                        </div>
                    }

                    <form asp-action="Apply" method="post" enctype="multipart/form-data" id="applyForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="internshipId" value="@Model.Id" />

                        @* CV YÜKLEME *@
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Özgeçmiş (CV)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fas fa-file-pdf text-danger"></i></span>
                                <input type="file" name="cvFile" id="cvFile" class="form-control border-light bg-light" accept=".pdf,.doc,.docx" required />
                            </div>
                            <div class="form-text small mt-1 text-muted">Sadece PDF veya Word (Maks 5MB)</div>
                        </div>

                        @* SERTİFİKA *@
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Sertifika / Proje (Opsiyonel)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fas fa-award text-warning"></i></span>
                                <input type="file" name="certFile" id="certFile" class="form-control border-light bg-light" accept=".pdf,.doc,.docx,.ppt,.pptx" />
                            </div>
                            <div class="form-text small mt-1 text-muted">Sertifika veya Sunum dosyası ekleyebilirsiniz.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold shadow-sm py-3 border-0"
                                    style="background: linear-gradient(to right, #11998e, #38ef7d);">
                                <i class="fas fa-paper-plane me-2"></i> Başvuruyu Gönder
                            </button>
                            <a asp-controller="Internship" asp-action="Index" class="btn btn-link text-muted text-decoration-none small text-center">
                                <i class="fas fa-arrow-left me-1"></i> İlanlara Geri Dön
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // ✅ 1. KRİTİK MÜHÜR: Akıllı Tavsiye Radarı (Döngü Kırıcı)
        @if (TempData["WrongDepartment"] != null)
        {
            var targetDeptId = TempData["UserDeptId"]; // Öğrencinin asıl bölüm ID'si

            <text>
                Swal.fire({
                    title: 'Bölüm Uyuşmazlığı! 🛡️',
                    text: 'Kardaşım bu ilan senin bölümüne uygun görünmüyor. Senin için en doğru ilanları süzmemi ister misin?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#11998e',
                    cancelButtonColor: '#d33',
                    confirmButtonText: '✅ Evet, Uygun İlanları Gör',
                    cancelButtonText: 'Kapat'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // 🚀 DÖNGÜYÜ BURADA KIRIYORUZ:
                        // Eğer targetDeptId boşsa varsayılan Index'e, doluysa filtreli Index'e yolla.
                        const deptId = '@targetDeptId';
                        if (deptId && deptId !== '0') {
                            window.location.href = '/Internship/Index?departmentId=' + deptId;
                        } else {
                            window.location.href = '/Internship/Index';
                        }
                    }
                });
            </text>
        }

        // ✅ 2. DOSYA KONTROL RADARI
        document.getElementById('applyForm').onsubmit = function (e) {
            const allowed = /(\.pdf|\.doc|\.docx|\.ppt|\.pptx)$/i;
            const cv = document.getElementById('cvFile').files[0];
            const cert = document.getElementById('certFile').files[0];

            if (cv && !allowed.exec(cv.name)) {
                Swal.fire('Hata!', 'Özgeçmiş formatı uygun değil!', 'error');
                e.preventDefault(); return false;
            }
            if (cert && !allowed.exec(cert.name)) {
                Swal.fire('Hata!', 'Sertifika formatı uygun değil!', 'error');
                e.preventDefault(); return false;
            }
            return true;
        };
    </script>
}