@model StajSistemi.Models.Internship

@{
    ViewData["Title"] = "Staj İlanı Oluştur";
}

@* ✅ SELECT2 VE SWEETALERT2 CSS *@
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
@* SweetAlert2 Tasarımı *@
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@sweetalert2/theme-bootstrap-4/bootstrap-4.css">

<style>
    /* Select2 Bootstrap Uyumu */
    .select2-container--default .select2-selection--multiple {
        border-color: #f8f9fa !important;
        background-color: #f8f9fa !important;
        border-radius: 10px !important;
        min-height: 45px;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                @* ✅ MÜHÜR: Başlık Kısmı *@
                <div class="card-header text-white text-center py-4" style="background: linear-gradient(to right, #2c3e50, #4ca1af) !important;">
                    <i class="fas fa-file-signature fa-3x mb-3"></i>
                    <h2 class="fw-bold mb-0">Staj İlanı Oluştur</h2>
                    <p class="small mb-0 opacity-75">Resmi Staj İlanı Yayınlama Portalı</p>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <div asp-validation-summary="All" class="alert alert-danger shadow-sm border-0 rounded-4 small mb-4"></div>

                    <form asp-action="Create" method="post" id="internshipForm">
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-12 mb-4">
                                <label asp-for="CompanyName" class="form-label fw-bold text-secondary">Şirket / Kurum Tam Adı</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-building text-muted"></i></span>
                                    <input asp-for="CompanyName" id="CompanyName" class="form-control border-light bg-light" placeholder="Örn: Sinop Teknopark" />
                                    <button type="button" class="btn btn-outline-danger" onclick="verifyMapLocation()" title="Haritada Konumu Doğrula">
                                        <i class="fas fa-map-marker-alt"></i> Konumu Test Et
                                    </button>
                                </div>
                                <span asp-validation-for="CompanyName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12 mb-4">
                                <label asp-for="CompanySector" class="form-label fw-bold text-secondary">Faaliyet Sektörü</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-chart-line text-muted"></i></span>
                                    <select asp-for="CompanySector" class="form-select border-light bg-light">
                                        <option value="">-- Sektör Seçiniz --</option>
                                        <option value="Bilişim, Yazılım ve Siber Güvenlik">Bilişim, Yazılım ve Siber Güvenlik</option>
                                        <option value="Eğitim ve Okul Öncesi Hizmetleri">Eğitim ve Okul Öncesi Hizmetleri</option>
                                        <option value="Dış Ticaret, Lojistik ve Tedarik Zinciri">Dış Ticaret, Lojistik ve Tedarik Zinciri</option>
                                        <option value="Endüstriyel Otomasyon ve Mekatronik">Endüstriyel Otomasyon ve Mekatronik</option>
                                        <option value="Mimarlık, Tasarım ve Dekorasyon">Mimarlık, Tasarım ve Dekorasyon</option>
                                        <option value="Tarım, Orman ve Çevre Teknolojileri">Tarım, Orman ve Çevre Teknolojileri</option>
                                        <option value="Medya ve Dijital Oyun Tasarımı">Medya ve Dijital Oyun Tasarımı</option>
                                        <option value="Diğer Hizmet Sektörleri">Diğer Hizmet Sektörleri</option>
                                    </select>
                                </div>
                                <span asp-validation-for="CompanySector" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CityId" class="form-label fw-bold text-secondary">Stajın Yapılacağı Şehir</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fas fa-map-marker-alt text-muted"></i></span>
                                <select asp-for="CityId" id="CitySelect" class="form-select border-light bg-light">
                                    <option value="">-- Şehir Seçiniz --</option>
                                    @if (ViewBag.Cities != null)
                                    {
                                        foreach (var item in (IEnumerable<StajSistemi.Models.City>)ViewBag.Cities)
                                        {
                                            <option value="@item.Id">@item.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Hedef Öğrenci Bölümleri (Çoklu Seçim)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fas fa-graduation-cap text-muted"></i></span>
                                <select name="selectedDepartmentIds" id="targetDepartment" class="form-control select2-multiple" multiple="multiple">
                                    @if (ViewBag.Departments != null)
                                    {
                                        // 🛡️ SİBER MÜHÜR: Hata sonrası seçilenleri hatırlamak için liste hazırlığı
                                        var selectedIds = ViewBag.SelectedDeptIds as int[] ?? new int[0];

                                        foreach (var item in (IEnumerable<StajSistemi.Models.Department>)ViewBag.Departments)
                                        {
                                            bool isSelected = selectedIds.Contains(item.Id);
                                            <option value="@item.Id" selected="@(isSelected ? "selected" : null)">@item.DepartmentName</option>
                                        }
                                    }
                                </select>
                            </div>
                            <small class="text-muted">🔍 Bölümleri arayabilir ve istediğin kadarını seçebilirsin.</small>
                        </div>

                        <div class="mb-4 p-3 rounded-4 border-2 border-dashed bg-light text-center">
                            <label class="form-label fw-bold text-dark"><i class="fas fa-calendar-check me-2"></i>Haftalık Çalışma Düzeni</label>
                            <div class="d-flex justify-content-center gap-3 mt-2">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="weeklyWorkDays" id="work5" value="5" checked>
                                    <label class="form-check-label" for="work5">Haftada 5 Gün</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="weeklyWorkDays" id="work6" value="6">
                                    <label class="form-check-label" for="work6">Haftada 6 Gün</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="StartDate" class="form-label fw-bold text-secondary">Başlangıç Tarihi</label>
                                <input asp-for="StartDate" id="startDate" type="date" class="form-control border-light bg-light" />
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="EndDate" class="form-label fw-bold text-secondary">Bitiş Tarihi</label>
                                <input asp-for="EndDate" id="endDate" type="date" class="form-control border-light bg-light" />
                                <small id="dateError" class="text-danger d-none fw-bold mt-1">Staj süresi en az 30 gün olmalıdır!</small>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Quota" class="form-label fw-bold text-secondary">Öğrenci Kontenjanı</label>
                            <input asp-for="Quota" type="number" class="form-control border-light bg-light" min="1" placeholder="Örn: 5" />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold text-secondary">İş Tanımı ve Detaylar</label>
                            <textarea asp-for="Description" class="form-control border-light bg-light" rows="3"></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3" style="background: linear-gradient(to right, #2c3e50, #4ca1af); border: none;">
                                <i class="fas fa-paper-plane me-2"></i> İlanı Yayınla
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted text-decoration-none small text-center">İptal ve Geri Dön</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    @* ✅ SELECT2 VE SWEETALERT2 JS *@
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function() {
            $('.select2-multiple').select2({
                placeholder: " Lütfen ilgili bölümleri seçiniz...",
                allowClear: true,
                width: '100%'
            });

            // 🛡️ SİBER RESMİ DOĞRULAMA
            document.getElementById("internshipForm").addEventListener("submit", function (e) {
                const startVal = document.getElementById("startDate").value;
                const endVal = document.getElementById("endDate").value;
                const deptVal = $('#targetDepartment').val();

                // 1. Bölüm Seçim Kontrolü (Resmi Dil)
                if (!deptVal || deptVal.length === 0) {
                    e.preventDefault();
                    Swal.fire({
                        title: 'Eksik Bilgi!',
                        text: 'İlan yayınlayabilmek için en az bir hedef bölüm seçmeniz gerekmektedir.',
                        icon: 'warning',
                        confirmButtonColor: '#2c3e50',
                        confirmButtonText: 'Anladım'
                    });
                    return false;
                }

                // 2. Tarih Farkı Kontrolü (Resmi Dil)
                if (startVal && endVal) {
                    const start = new Date(startVal);
                    const end = new Date(endVal);
                    const diffTime = Math.abs(end - start);
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                    if (diffDays < 30) {
                        e.preventDefault();
                        Swal.fire({
                            title: 'Geçersiz Tarih Aralığı!',
                            text: 'Staj süresi yönetmelik gereği en az 30 gün olarak belirlenmelidir.',
                            icon: 'error',
                            confirmButtonColor: '#c0392b',
                            confirmButtonText: 'Düzenle'
                        });
                        return false;
                    }
                }
            });
        });

        // 🗺️ Konum Testi Mesajı
        function verifyMapLocation() {
            var company = document.getElementById("CompanyName").value;
            var citySelect = document.getElementById("CitySelect");
            var cityText = citySelect.options[citySelect.selectedIndex].text;

            if (company && cityText && citySelect.value !== "") {
                var searchQuery = encodeURIComponent(company + " " + cityText);
                window.open("https://www.google.com/maps/search/?api=1&query=" + searchQuery, '_blank');
            } else {
                Swal.fire({
                    title: 'Eksik Parametre!',
                    text: 'Konum doğrulaması yapabilmek için lütfen önce Şirket Adı ve Şehir bilgilerini doldurunuz.',
                    icon: 'info',
                    confirmButtonColor: '#2980b9'
                });
            }
        }
    </script>
}