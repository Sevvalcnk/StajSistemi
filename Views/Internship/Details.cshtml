@model StajSistemi.Models.Internship

@{
    ViewData["Title"] = Model.Name + " - Detaylar";
}

<div class="container py-5 techNode-fade-in">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            @* --- 🛡️ ÜST KART: ŞİRKET VE BAŞLIK --- *@
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-dark p-4 border-0 d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold text-white mb-0">@Model.Name</h3>
                        <p class="text-info mb-0 small"><i class="fas fa-building me-1"></i> @Model.CompanyName</p>
                    </div>
                    <a asp-action="Index" class="btn btn-outline-light btn-sm rounded-pill px-3">
                        <i class="fas fa-arrow-left me-1"></i> İlanlara Dön
                    </a>
                </div>

                <div class="card-body p-5 bg-white">
                    <div class="row g-4 mb-5">
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-4 text-center">
                                <i class="fas fa-map-marker-alt text-danger mb-2 fs-4"></i>
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Konum</small>
                                <span class="fw-bold text-dark">@(Model.City?.Name ?? Model.CityName ?? "Belirtilmemiş")</span>
                            </div>
                        </div>

                        @* ✅ GÜNCELLEME: Many-to-Many Mührü *@
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-4 text-center">
                                <i class="fas fa-graduation-cap text-primary mb-2 fs-4"></i>
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Hedef Bölümler</small>
                                <div class="d-flex flex-wrap justify-content-center">
                                    @if (Model.InternshipDepartments != null && Model.InternshipDepartments.Any())
                                    {
                                        foreach (var deptMap in Model.InternshipDepartments)
                                        {
                                            <span class="badge bg-soft-info text-info border rounded-pill px-2 m-1">
                                                @(deptMap.Department?.DepartmentName ?? "Bilinmiyor")
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="fw-bold text-dark">Genel</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-4 text-center">
                                <i class="fas fa-users text-success mb-2 fs-4"></i>
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Kalan Kontenjan</small>
                                <span class="fw-bold text-dark">@Model.Quota Kişi</span>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold text-dark mb-3"><i class="fas fa-file-alt me-2 text-primary"></i>İş Tanımı ve Detaylar</h5>
                    <div class="p-4 bg-light rounded-4 mb-5 shadow-sm border-start border-4 border-primary">
                        <p class="text-secondary" style="line-height: 1.8;">@Model.Description</p>
                    </div>

                    @* --- 🚀 BAŞVURU BUTONU --- *@
                    <div class="d-grid">
                        @if (Model.Status == ApplicationStatus.Active && Model.Quota > 0)
                        {
                            <a asp-action="Apply" asp-route-id="@Model.Id" class="btn btn-primary btn-lg rounded-pill shadow-sm py-3 fw-bold">
                                <i class="fas fa-paper-plane me-2"></i> Hemen Başvur
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-lg rounded-pill py-3 fw-bold" disabled>İlan Kapalı</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>