@model StajSistemi.Models.Internship

@{
    ViewData["Title"] = "İlanı Güncelle";
}

@* 🎨 TASARIM MÜHÜRÜ: Modern Checkbox ve Liste Stilleri *@
<style>
    .dept-selection-container {
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 15px;
        padding: 15px;
        max-height: 250px;
        overflow-y: auto;
        transition: 0.3s;
    }

        .dept-selection-container:focus-within {
            border-color: #4361ee;
            box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
        }

    .dept-item {
        display: flex;
        align-items: center;
        padding: 8px 12px;
        margin-bottom: 5px;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.2s;
        border: 1px solid transparent;
        color: #475569;
    }

        .dept-item:hover {
            background: #edf2ff;
            color: #4361ee;
        }

        .dept-item input[type="checkbox"] {
            width: 18px;
            height: 18px;
            margin-right: 12px;
            cursor: pointer;
            accent-color: #4361ee;
        }

        .dept-item.selected {
            background: #eef2ff;
            border-color: #c3dafe;
            font-weight: 600;
            color: #1e3a8a;
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                @* Başlık Kısmı *@
                <div class="card-header text-white text-center py-4" style="background: linear-gradient(to right, #1e3c72, #2a5298) !important;">
                    <i class="fas fa-edit fa-3x mb-3"></i>
                    <h2 class="fw-bold mb-0">İlan Bilgilerini Güncelle</h2>
                    <p class="small mb-0 opacity-75">Mevcut staj ilanını buradan güncelleyebilirsiniz.</p>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Edit" method="post" id="internshipForm">
                        @Html.AntiForgeryToken()

                        @* 🛡️ MÜHÜR: Gizli Alanlar *@
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Name" />
                        <input type="hidden" asp-for="Status" />
                        <input type="hidden" asp-for="CreatedDate" />
                        <input type="hidden" asp-for="IsDeleted" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm small mb-4"></div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="CompanyName" class="form-label fw-bold text-secondary">Şirket/Kurum Adı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-building text-muted"></i></span>
                                    <input asp-for="CompanyName" class="form-control border-light bg-light" placeholder="Örn: ASELSAN" />
                                </div>
                                <span asp-validation-for="CompanyName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="CityId" class="form-label fw-bold text-secondary">Staj Şehri</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-map-marker-alt text-muted"></i></span>
                                    <select asp-for="CityId" class="form-select border-light bg-light" asp-items="@(new SelectList(ViewBag.Cities, "Id", "Name"))">
                                        <option value="">-- Şehir Seçiniz --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="CityId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CompanySector" class="form-label fw-bold text-secondary">Faaliyet Sektörü</label>
                            <select asp-for="CompanySector" class="form-select border-light bg-light">
                                <option value="">-- Sektör Seçiniz --</option>
                                <option value="Bilişim ve Yazılım Teknolojileri">Bilişim ve Yazılım Teknolojileri</option>
                                <option value="Endüstriyel Otomasyon ve Robotik">Endüstriyel Otomasyon ve Robotik</option>
                                <option value="Uluslararası Ticaret ve Lojistik">Uluslararası Ticaret ve Lojistik</option>
                                <option value="Gümrük ve Tedarik Zinciri Yönetimi">Gümrük ve Tedarik Zinciri Yönetimi</option>
                                <option value="Eğitim ve Sosyal Hizmetler">Eğitim ve Sosyal Hizmetler</option>
                                <option value="Mimarlık ve İç Mekan Tasarımı">Mimarlık ve İç Mekan Tasarımı</option>
                                <option value="Mobilya ve Dekorasyon Üretimi">Mobilya ve Dekorasyon Üretimi</option>
                                <option value="Orman Endüstrisi ve Çevre Yönetimi">Orman Endüstrisi ve Çevre Yönetimi</option>
                            </select>
                            <span asp-validation-for="CompanySector" class="text-danger small"></span>
                        </div>

                        @* ✅ GÜNCELLEME: Modern Checkbox Bölüm Seçimi *@
                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">
                                <i class="fas fa-graduation-cap me-2"></i>Hedef Öğrenci Bölümleri
                            </label>

                            <div class="dept-selection-container shadow-sm" id="deptCheckboxList">
                                @if (ViewBag.Departments != null)
                                {
                                    foreach (var item in (IEnumerable<StajSistemi.Models.Department>)ViewBag.Departments)
                                    {
                                        bool isSelected = Model.InternshipDepartments != null &&
                                        Model.InternshipDepartments.Any(d => d.DepartmentId == item.Id);

                                        <label class="dept-item @(isSelected ? "selected" : "")">
                                            <input type="checkbox" name="selectedDepartmentIds" value="@item.Id"
                                            @(isSelected ? "checked" : "") onchange="this.parentElement.classList.toggle('selected', this.checked)">
                                            <span>@item.DepartmentName</span>
                                        </label>
                                    }
                                }
                            </div>
                            <div class="d-flex justify-content-between mt-2">
                                <small class="text-muted"><i class="fas fa-info-circle me-1"></i> Uygun bölümleri yanındaki kutucuklardan mühürleyebilirsin.</small>
                                <small class="fw-bold text-primary">Seçilenleri Kontrol Et!</small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="StartDate" class="form-label fw-bold text-secondary">Başlangıç Tarihi</label>
                                <input asp-for="StartDate" id="startDate" type="date" class="form-control border-light bg-light" />
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="EndDate" class="form-label fw-bold text-secondary">Bitiş Tarihi</label>
                                <input asp-for="EndDate" id="endDate" type="date" class="form-control border-light bg-light" />
                                <small id="dateError" class="text-danger d-none fw-bold mt-1">Staj süresi en az 30 gün olmalıdır!</small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Quota" class="form-label fw-bold text-secondary">Öğrenci Kontenjanı</label>
                                <input asp-for="Quota" type="number" class="form-control border-light bg-light" min="1" />
                                <span asp-validation-for="Quota" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="Status" class="form-label fw-bold text-secondary">Yayın Durumu</label>
                                <select asp-for="Status" class="form-select border-light bg-light" asp-items="Html.GetEnumSelectList<StajSistemi.Models.ApplicationStatus>()"></select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold text-secondary">İş Tanımı ve Detaylar</label>
                            <textarea asp-for="Description" class="form-control border-light bg-light" rows="4" placeholder="Stajyerden beklentilerinizi buraya mühürleyin..."></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm py-3" style="background: linear-gradient(to right, #1e3c72, #2a5298); border: none;">
                                <i class="fas fa-save me-2"></i> Değişiklikleri Mühürle
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted text-decoration-none small text-center">İptal ve Geri Dön</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById("internshipForm").addEventListener("submit", function (e) {
            const startVal = document.getElementById("startDate").value;
            const endVal = document.getElementById("endDate").value;

            // 🛡️ SİBER DÜZELTME: Checkbox'ların seçili olup olmadığını kontrol ediyoruz
            const selectedCheckboxes = document.querySelectorAll('input[name="selectedDepartmentIds"]:checked');
            const errorElement = document.getElementById("dateError");

            // 1. Bölüm Seçim Kontrolü
            if (selectedCheckboxes.length === 0) {
                e.preventDefault();
                alert("⚠️ Kardaşım, en az bir hedef bölüm seçmelisin!");
                return false;
            }

            // 2. Tarih Kontrolü
            if (!startVal || !endVal) return;

            const start = new Date(startVal);
            const end = new Date(endVal);
            const diffTime = Math.abs(end - start);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

            if (diffDays < 30) {
                e.preventDefault();
                errorElement.classList.remove("d-none");
                alert("❌ Güncelleme Başarısız: Staj süresi yönetmelik gereği en az 30 gün olmalıdır!");
            }
        });
    </script>
}