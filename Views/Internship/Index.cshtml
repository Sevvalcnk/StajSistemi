@model IEnumerable<StajSistemi.Models.Internship>

@{
    ViewData["Title"] = "Staj İlanları";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-0"><i class="fas fa-briefcase me-2"></i>Staj Sistemi</h2>
            <p class="text-muted small">Aktif ilanları inceleyebilir ve başvuruda bulunabilirsiniz.</p>
        </div>

        @if (User.IsInRole("Advisor") || User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success rounded-pill shadow-sm px-4">
                <i class="fas fa-plus-circle me-1"></i> Yeni İlan Oluştur
            </a>
        }
    </div>

    @* Bildirim Mesajları *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="px-4 py-3">İlan Bilgisi / Şirket</th>
                            <th class="py-3">Hedef Bölüm</th>
                            <th class="py-3">Staj Tarihleri</th>
                            <th class="py-3 text-center">Kontenjan</th>
                            <th class="py-3 text-center">Durum</th>
                            <th class="py-3 text-end px-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-folder-open fa-3x mb-3 opacity-25"></i><br>
                                    Henüz yayınlanmış bir staj ilanı bulunmuyor.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3">
                                        <div class="fw-bold text-dark">@item.Name</div>
                                        <div class="small text-muted">@item.CompanyName (@item.CompanySector)</div>
                                    </td>
                                    <td class="py-3">
                                        <span class="badge bg-soft-info text-info border border-info rounded-pill px-3">
                                            <i class="fas fa-graduation-cap me-1"></i>
                                            @(item.Department != null ? item.Department.DepartmentName : "Genel")
                                        </span>
                                    </td>
                                    <td class="py-3">
                                        <div class="small fw-bold text-secondary">
                                            <i class="far fa-calendar-alt me-1"></i> @item.StartDate.ToString("dd.MM.yyyy")
                                        </div>
                                        <div class="small text-muted">
                                            <i class="fas fa-long-arrow-alt-down ms-1"></i> @item.EndDate.ToString("dd.MM.yyyy")
                                        </div>
                                    </td>
                                    <td class="py-3 text-center">
                                        <span class="fw-bold text-primary">@item.Quota</span>
                                    </td>
                                    <td class="py-3 text-center">
                                        @if (item.Status == "Aktif")
                                        {
                                            if (item.Quota <= 0)
                                            {
                                                <span class="badge bg-danger rounded-pill">Kontenjan Dolu</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success rounded-pill">Yayında</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill">@item.Status</span>
                                        }
                                    </td>
                                    <td class="py-3 text-end px-4">
                                        @if (User.IsInRole("Student"))
                                        {
                                            if (item.Quota > 0 && item.Status == "Aktif")
                                            {
                                                <a asp-action="Apply" asp-route-id="@item.Id" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                                                    <i class="fas fa-paper-plane me-1"></i> Başvur
                                                </a>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-light border rounded-pill px-3 text-muted" disabled>Kapalı</button>
                                            }
                                        }

                                        @if (User.IsInRole("Advisor") || User.IsInRole("Admin"))
                                        {
                                            <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary border-0 px-3" title="Düzenle">
                                                    <i class="fas fa-edit"></i>
                                                </a>

                                                @* 🛡️ GÜVENLİK MÜHRÜ: 404 Hatasını bitiren POST formu *@
                                                <form asp-action="DeleteInternship" asp-route-id="@item.Id" method="post"
                                                      onsubmit="return confirm('Bu ilanı sistemden kaldırmak üzeresiniz. Emin misiniz?');"
                                                      style="display: contents;">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0 px-3" title="Sil">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-info {
        background-color: #e0f7fa;
    }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: 0.3s;
    }

    /* Silme butonunun hizasını korumak için */
    .btn-group form {
        margin: 0;
        padding: 0;
    }
</style>