@model IEnumerable<StajSistemi.Models.InternshipApplication>

@{
    ViewData["Title"] = "Başvuru Sonuçlarım";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">
            <i class="fas fa-clipboard-list text-primary me-2"></i> Başvuru Sonuçlarım
        </h2>
        <a asp-controller="StudentPanel" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
            <i class="fas fa-arrow-left me-1"></i> Panele Dön
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-primary text-white">
                    <tr>
                        <th class="ps-4">Şirket / Kurum</th>
                        <th>Departman</th>
                        <th>Başvuru Tarihi</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="fas fa-folder-open fa-3x text-muted mb-3 d-block"></i>
                                <p class="text-muted fw-bold">Henüz herhangi bir başvurunuz bulunmuyor.</p>
                                @* ✅ DÜZELTME: Doğru Controller'a yönlendirme *@
                                <a asp-controller="Internship" asp-action="Index" class="btn btn-sm btn-primary rounded-pill">İlanları Gör</a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    @* ✅ KRİTİK NOT: Internship modelindeki isimlendirmene (CompanyName/Name) dikkat et! *@
                                    <div class="fw-bold">@item.Internship?.Name</div>
                                    <small class="text-muted">@item.Internship?.CompanySector</small>
                                </td>
                                <td>@item.Internship?.Department?.DepartmentName</td>
                                <td>@item.ApplicationDate.ToString("dd MMMM yyyy")</td>
                                <td>
                                    <span class="badge rounded-pill px-3 py-2
                                        @(item.Status == "Beklemede" ? "bg-warning text-dark" :
                                          item.Status == "Reddedildi" ? "bg-danger" : "bg-success")">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    @if (!string.IsNullOrEmpty(item.CVPath))
                                    {
                                        <a href="/uploads/cv/@item.CVPath" target="_blank" class="btn btn-sm btn-light border rounded-pill">
                                            <i class="fas fa-file-pdf text-danger me-1"></i> CV'm
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>