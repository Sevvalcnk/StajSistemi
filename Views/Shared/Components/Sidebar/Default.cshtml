@if (User.IsInRole("Advisor") || User.IsInRole("Admin"))
{
    @* HOCA PANELİ İÇİN LİNK *@
    <a asp-controller="Chat" asp-action="Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
        <span><i class="fas fa-comments me-2 text-info"></i> Gelen Mesajlar</span>
        <span id="unread-badge-advisor" class="badge bg-danger animate__animated animate__pulse animate__infinite badge-notify @(ViewBag.UnreadMessagesCount > 0 ? "" : "d-none")">
            @ViewBag.UnreadMessagesCount
        </span>
    </a>
}
else if (User.IsInRole("Student"))
{
    @* ÖĞRENCİ PANELİ İÇİN LİNK *@
    <a asp-controller="Chat" asp-action="Index" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
        <span><i class="fas fa-comment-dots me-2 text-info"></i> Mesajlarım</span>
        <span id="unread-badge-student" class="badge bg-danger animate__animated animate__pulse animate__infinite badge-notify @(ViewBag.UnreadMessagesCount > 0 ? "" : "d-none")">
            @ViewBag.UnreadMessagesCount
        </span>
    </a>
}