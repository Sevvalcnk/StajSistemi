@using Microsoft.AspNetCore.Identity
@using StajSistemi.Models
@using Microsoft.EntityFrameworkCore
@inject UserManager<AppUser> UserManager
@inject StajSistemi.data.ApplicationDbContext _context

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - StajSistemi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    @* ✅ SweetAlert2 ve Google Fonts *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        body {
            overflow-x: hidden;
            background-color: #f4f7f6;
            font-family: 'Inter', sans-serif;
        }

        #wrapper {
            display: flex;
            width: 100%;
            align-items: stretch;
        }

        /* 🛡️ SİBER MENÜ ZIRHI */
        #sidebar-wrapper {
            min-height: 100vh;
            width: 260px;
            background: #2c3e50;
            color: white;
            position: fixed;
            left: 0;
            top: 0;
            z-index: 1050 !important;
            transition: transform 0.3s ease-in-out;
            transform: translateX(-260px);
            box-shadow: 5px 0 15px rgba(0,0,0,0.1);
        }

            #sidebar-wrapper .sidebar-heading {
                padding: 1.5rem 1.25rem;
                font-size: 1.3rem;
                font-weight: 800;
                border-bottom: 1px solid rgba(255,255,255,0.1);
                text-align: center;
            }

            #sidebar-wrapper .list-group-item {
                background: transparent;
                color: rgba(255,255,255,0.7);
                border: none;
                padding: 1rem 1.5rem;
                transition: all 0.3s;
            }

                #sidebar-wrapper .list-group-item:hover {
                    background: rgba(255,255,255,0.1);
                    color: white;
                    padding-left: 2rem;
                }

                #sidebar-wrapper .list-group-item.active-link {
                    background: rgba(67, 97, 238, 0.2);
                    color: white;
                    border-left: 4px solid #4361ee;
                }

        #page-content-wrapper {
            width: 100%;
            flex: 1;
            transition: all 0.3s ease-in-out;
            margin-left: 0;
        }

        .navbar {
            background: white;
            border-bottom: 1px solid #e3e6f0;
            padding: 0.8rem 1rem;
        }

        /* 📱 MOBİL TETİKLEYİCİ VE DÜZELTME (768px ALTI) */
        @@media (max-width: 767.98px) {
            body.sb-sidenav-toggled #sidebar-wrapper {
                transform: translateX(0) !important;
            }
            /* Karartma Overlay'i */
            body.sb-sidenav-toggled #wrapper::after {
                content: "";
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background: rgba(0,0,0,0.4);
                z-index: 1040;
            }
            /* Mobilde kartların ve başlıkların taşmasını önleyen siber yama */
            .container-fluid {
                padding-left: 10px !important;
                padding-right: 10px !important;
            }

            h2, h3, .display-4 {
                font-size: 1.5rem !important; /* Büyük başlıkları mobilde dizginliyoruz */
            }
        }

        /* 💻 MASAÜSTÜ GÖRÜNÜM (768px ÜSTÜ) */
        @@media (min-width: 768px) {
            #sidebar-wrapper {
                transform: translateX(0);
            }

            #page-content-wrapper {
                margin-left: 260px;
            }

            body.sb-sidenav-toggled #sidebar-wrapper {
                transform: translateX(-260px) !important;
            }

            body.sb-sidenav-toggled #page-content-wrapper {
                margin-left: 0 !important;
            }
        }

        .menu-locked {
            opacity: 0.5;
            cursor: not-allowed !important;
        }

            .menu-locked i {
                color: #95a5a6 !important;
            }
    </style>
</head>
<body>
    <div id="wrapper">
        <div id="sidebar-wrapper">
            <div class="sidebar-heading">
                <i class="fas fa-graduation-cap me-2 text-primary"></i>StajSistemi
            </div>
            <div class="list-group list-group-flush mt-3">
                <a asp-controller="Home" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="fas fa-home me-2 text-secondary"></i> Ana Sayfa
                </a>

                @if (User.Identity.IsAuthenticated)
                {
                    if (User.IsInRole("Advisor") || User.IsInRole("Admin"))
                    {
                        <a asp-controller="Advisor" asp-action="InternshipApplications" class="list-group-item list-group-item-action bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-envelope-open-text me-2 text-warning"></i> Gelen Başvurular</span>
                            @if (ViewBag.NewApplicationsCount != null && (int)ViewBag.NewApplicationsCount > 0)
                            {
                                <span class="badge rounded-pill bg-danger shadow-sm">@ViewBag.NewApplicationsCount</span>
                            }
                        </a>
                        <a asp-controller="Advisor" asp-action="Index" class="list-group-item list-group-item-action">
                            <i class="fas fa-users me-2 text-danger"></i> Öğrenci Listesi
                        </a>
                        <a asp-controller="Advisor" asp-action="Archive" class="list-group-item list-group-item-action">
                            <i class="fas fa-archive me-2 text-warning"></i> Siber Arşiv
                        </a>
                    }

                    if (User.IsInRole("Student"))
                    {
                        <a asp-controller="StudentPanel" asp-action="Index" class="list-group-item list-group-item-action">
                            <i class="fas fa-user-graduate me-2 text-primary"></i> Kariyer Panelim
                        </a>
                        <a asp-controller="StudentPanel" asp-action="Applications" class="list-group-item list-group-item-action">
                            <i class="fas fa-file-contract me-2 text-warning"></i> Başvurularım
                        </a>
                        <a asp-controller="StudentPanel" asp-action="Results" class="list-group-item list-group-item-action">
                            <i class="fas fa-poll me-2 text-info"></i> Başvuru Sonuçlarım
                        </a>

                        var currentUserId = UserManager.GetUserId(User);
                        bool isInternshipApproved = false;
                        if (currentUserId != null)
                        {
                            isInternshipApproved = _context.InternshipApplications
                            .Any(a => a.AppUserId == int.Parse(currentUserId) && a.Status == ApplicationStatus.Approved);
                        }

                        if (isInternshipApproved)
                        {
                            <a asp-controller="StudentPanel" asp-action="Documents" class="list-group-item list-group-item-action">
                                <i class="fas fa-file-signature me-2 text-success"></i> <strong>Staj Defterim (Aktif)</strong>
                            </a>
                        }
                        else
                        {
                            <div class="list-group-item menu-locked" title="Stajınız onaylandığında açılacaktır.">
                                <i class="fas fa-lock me-2"></i> <span class="small">Staj Defterim (Kilitli)</span>
                            </div>
                        }
                    }

                    @await Component.InvokeAsync("Sidebar")

                    <div class="border-top my-2 opacity-25"></div>
                    <a asp-controller="Internship" asp-action="Index" class="list-group-item list-group-item-action">
                        <i class="fas fa-search me-2 text-success"></i> Staj İlanları
                    </a>
                }
            </div>
        </div>

        <div id="page-content-wrapper" class="d-flex flex-column">
            <nav class="navbar navbar-expand-lg navbar-light shadow-sm sticky-top">
                <div class="container-fluid">
                    <button class="btn btn-primary shadow-sm border-0" id="sidebarToggle" type="button" style="background: linear-gradient(to right, #2c3e50, #4ca1af);">
                        <i class="fas fa-bars"></i>
                    </button>

                    <div class="ms-auto d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            var user = await UserManager.GetUserAsync(User);
                            <span class="me-3 d-none d-md-inline fw-bold text-dark">
                                <i class="fas fa-user-circle me-1 text-primary"></i> @(user?.FullName ?? User.Identity.Name)
                            </span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold">Çıkış</button>
                            </form>
                        }
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-2 p-md-4">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            $(document).on("click", "#sidebarToggle", function (e) {
                e.preventDefault();
                $("body").toggleClass("sb-sidenav-toggled");
            });

            // ✅ Mobilde menü açıkken dışarıya tıklandığında menüyü kapatan liyakatli dokunuş
            $(document).on("click", function (e) {
                if ($("body").hasClass("sb-sidenav-toggled") && window.innerWidth < 768) {
                    if (!$(e.target).closest("#sidebar-wrapper, #sidebarToggle").length) {
                        $("body").removeClass("sb-sidenav-toggled");
                    }
                }
            });
        });

        // 🛰️ SIGNALR SİBER BAĞLANTI
        const connectionGlobal = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        connectionGlobal.start().catch(err => console.error(err.toString()));

        connectionGlobal.on("ReceiveNewMessage", function (senderId, content) {
            new Audio('https://www.soundjay.com/buttons/beep-07a.mp3').play().catch(e => {});

            Swal.mixin({
                toast: true, position: 'top-end', showConfirmButton: false, timer: 4000, timerProgressBar: true
            }).fire({
                icon: 'info', title: 'Yeni Mesaj!', text: content.length > 40 ? content.substring(0, 40) + "..." : content
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>