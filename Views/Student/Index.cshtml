@model IEnumerable<StajSistemi.DTOs.StudentDto>
<div class="container mt-5">
    <div class="card shadow-sm border-0 rounded-4 p-4">
        <h2 class="fw-bold">Öğrenci Yönetimi</h2>
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Öğrenci</th>
                    <th>Bölüm</th>
                    <th>GPA</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name @item.Surname</td>
                        @* İşte burası artık "Bilgisayar Programcılığı" gibi dolacak! *@
                        <td><span class="badge bg-light text-dark">@(item.DepartmentName ?? "Belirtilmedi")</span></td>
                        <td>
                            <div class="progress" style="height: 10px; width: 100px;">
                                @* GPA 3.0 ve üzeriyse YEŞİL yanacak! *@
                                <div class="progress-bar @(item.GPA >= 3.0 ? "bg-success" : "bg-warning")"
                                     style="width: @(item.GPA * 25)%"></div>
                            </div>
                            <small>@item.GPA</small>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>