@model IEnumerable<StajSistemi.DTOs.StudentDto>

@{
    ViewData["Title"] = "Öğrenci Listesi";
}

<h1>Öğrenci Listesi</h1>

<p>
    <a class="btn btn-primary" href="/Student/Create">Yeni Öğrenci Ekle</a>
</p>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Adı</th>
            <th>Soyadı</th>
            <th>Öğrenci No</th>
            <th>GPA</th>
            <th>Email</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Surname</td>
                <td>@item.StudentNo</td>
                <td>@item.GPA</td>
                <td>@item.Email</td>
                <td>
                    <a class="btn btn-sm btn-info" href="/Student/Edit/@item.Id">Düzenle</a> |
                    <a class="btn btn-sm btn-danger" href="/Student/Delete/@item.Id">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>