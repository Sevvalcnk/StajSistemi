@model IEnumerable<StajSistemi.DTOs.StudentDto>

@{
    ViewData["Title"] = "Öğrenci Yönetimi";
}

<style>
    /* Hover efektini biraz daha belirginleştirelim */
    .transition {
        transition: all 0.3s ease;
    }

    .hover-up:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .bg-soft-primary {
        background-color: rgba(37, 140, 251, 0.1);
    }
</style>

<div class="container mt-5 techNode-fade-in">
    <div class="card shadow-lg border-0 rounded-4 p-4 bg-white">
        @* --- 🛡️ BAŞLIK VE AKSİYONLAR --- *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0 text-dark">
                    <i class="fas fa-users-cog me-2 text-primary"></i>Öğrenci Yönetimi
                </h2>
                <small class="text-muted">Sisteme kayıtlı stajyer öğrencilerin listesi ve analizleri.</small>
            </div>
            <div class="d-flex align-items-center gap-3">
                @* ✅ MÜHÜR: Yeni Öğrenci butonu buradan kaldırıldı, artık öğrenciler kendileri kayıt olacak *@
                <span class="badge bg-light text-muted border px-3 py-2 rounded-pill shadow-sm d-none d-md-inline-block">
                    <i class="fas fa-user-graduate me-1 text-info"></i> Toplam: @(Model?.Count() ?? 0) Öğrenci
                </span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-hover">
                <thead class="bg-light">
                    <tr class="text-secondary small text-uppercase fw-bold">
                        <th class="border-0 rounded-start-pill ps-4 py-3">Öğrenci Bilgisi</th>
                        <th class="border-0 py-3">Bölüm</th>
                        <th class="border-0 py-3">Akademik Durum (GPA)</th>
                        <th class="border-0 rounded-end-pill text-center py-3">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="transition">
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <img src="https://ui-avatars.com/api/?name=@item.Name+@item.Surname&background=random&color=fff&size=40"
                                             class="rounded-circle me-3 shadow-sm border border-2 border-white" alt="Profil">
                                        <div>
                                            <span class="fw-bold text-dark d-block text-capitalize">@item.Name @item.Surname</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-soft-primary text-primary border border-primary-subtle px-3 rounded-pill fw-bold" style="font-size: 0.75rem;">
                                        <i class="fas fa-graduation-cap me-1"></i> @(item.DepartmentName ?? "Bölüm Belirtilmedi")
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="progress me-2" style="height: 8px; width: 80px; border-radius: 10px; background-color: #eee;">
                                            @{
                                                var gpaValue = item.GPA ?? 0.0;
                                                var barColor = gpaValue >= 3.0 ? "bg-success" : (gpaValue >= 2.0 ? "bg-info" : "bg-warning");
                                                var progressValue = (gpaValue * 25.0);
                                            }
                                            <div class="progress-bar @barColor progress-bar-striped progress-bar-animated"
                                                 style="width: @progressValue.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                        </div>
                                        <span class="fw-bold small @(gpaValue >= 2.0 ? "text-dark" : "text-danger")">
                                            @(item.GPA?.ToString("F2") ?? "0.00")
                                        </span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-controller="Student" asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-info rounded-pill text-white fw-bold shadow-sm px-3 py-2 transition hover-up">
                                            <i class="fas fa-chart-pie me-1"></i> Analiz
                                        </a>

                                        <form asp-controller="Student" asp-action="Delete" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Bu öğrenciyi arşive kaldırmak istediğinize emin misiniz?');"
                                              style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill fw-bold shadow-sm px-3 py-2 transition hover-up">
                                                <i class="fas fa-archive me-1"></i> Arşivle
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="fas fa-user-slash fa-3x text-muted opacity-25 mb-3"></i>
                                <p class="text-muted fw-bold">Henüz kayıtlı veya staj başvurusu yapmış bir öğrenci bulunmuyor.</p>
                                @* ✅ MÜHÜR: Buradaki eylemsiz link de kaldırıldı *@
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>