@model IEnumerable<StajSistemi.DTOs.StudentDto>

<div class="container mt-5 techNode-fade-in">
    <div class="card shadow-lg border-0 rounded-4 p-4 bg-white">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0 text-dark"><i class="fas fa-users-cog me-2 text-primary"></i>Öğrenci Yönetimi</h2>
            <span class="badge bg-light text-muted border px-3 py-2 rounded-pill">Toplam: @Model.Count() Öğrenci</span>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-hover">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0 rounded-start-pill ps-4">Öğrenci</th>
                        <th class="border-0">Bölüm</th>
                        <th class="border-0">Akademik Durum (GPA)</th>
                        <th class="border-0 rounded-end-pill text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="https://ui-avatars.com/api/?name=@item.Name+@item.Surname&background=random&color=fff&size=40" class="rounded-circle me-3 shadow-sm">
                                    <span class="fw-bold text-dark">@item.Name @item.Surname</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border px-3 rounded-pill fw-normal">
                                    @(item.DepartmentName ?? "Belirtilmedi")
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="progress me-2" style="height: 10px; width: 100px; border-radius: 10px;">
                                        @* GPA 3.0 ve üzeriyse YEŞİL, 2.0-3.0 arası BİLGİ, altı TURUNCU yanacak! *@
                                        @{
                                            var barColor = item.GPA >= 3.0 ? "bg-success" : (item.GPA >= 2.0 ? "bg-info" : "bg-warning");
                                            var progressValue = (item.GPA * 25);
                                        }
                                        <div class="progress-bar @barColor progress-bar-striped"
                                             style="width: @progressValue%"></div>
                                    </div>
                                    <span class="fw-bold small text-muted">@item.GPA</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    @* ✅ MÜHÜR 1: Kariyer Detay Butonu *@
                                    <a asp-controller="Advisor" asp-action="StudentDetails" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-info rounded-pill text-white fw-bold shadow-sm px-3 py-2 transition hover-shadow">
                                        <i class="fas fa-eye me-1"></i> Kariyer
                                    </a>

                                    @* ✅ MÜHÜR 2: Soft Delete (Silme) Butonu *@
                                    @* Güvenlik için silme işlemini POST form ile yapıyoruz *@
                                    <form asp-controller="Advisor" asp-action="Delete" asp-route-id="@item.Id" method="post"
                                          onsubmit="return confirm('Bu öğrenciyi arşive kaldırmak istediğinize emin misiniz?');"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill fw-bold shadow-sm px-3 py-2">
                                            <i class="fas fa-trash-alt me-1"></i> Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>