@model IEnumerable<StajSistemi.Models.InternshipApplication>

@{
    ViewData["Title"] = "Gelen Başvurular";
}

<div class="container py-4">
    @* --- 🛡️ ÜST BAŞLIK VE ÖZET KARTI --- *@
    <div class="glass-card p-4 shadow-lg border-0 rounded-4 bg-white mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h4 class="fw-bold mb-1 text-dark">
                    <i class="fas fa-inbox text-primary me-2"></i>Gelen Staj Başvuruları
                </h4>
                <p class="text-muted small mb-0">Sisteme düşen tüm öğrenci başvurularını buradan mühürleyebilirsin.</p>
            </div>
            <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2 border">
                Toplam: @(Model?.Count() ?? 0) Başvuru
            </span>
        </div>
    </div>

    @* --- 📋 BAŞVURU TABLOSU --- *@
    <div class="glass-card shadow-lg border-0 rounded-4 bg-white overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Öğrenci Bilgisi</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Şirket / Kurum</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center">Departman</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted text-center">Durum</th>
                        <th class="pe-4 py-3 text-uppercase small fw-bold text-muted text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-soft-primary text-primary rounded-circle me-3 d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px;">
                                            @(item.AppUser?.FirstName?[0])@(item.AppUser?.LastName?[0])
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.AppUser?.FirstName @item.AppUser?.LastName</div>
                                            <small class="text-muted">No: @(item.AppUser?.StudentNo ?? "---")</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <div class="fw-bold text-dark">@(item.Internship?.CompanyName ?? "Belirtilmemiş")</div>
                                    <small class="text-muted"><i class="fas fa-map-marker-alt me-1"></i> @(item.Internship?.City?.Name ?? "Konum Yok")</small>
                                </td>
                                <td class="py-3 text-center">
                                    <span class="badge bg-light text-dark border rounded-pill fw-normal px-3">
                                        @(item.Internship?.Department?.DepartmentName ?? "Genel")
                                    </span>
                                </td>
                                <td class="py-3 text-center">
                                    @{
                                        var bgClass = "bg-warning text-dark";
                                        var icon = "fa-clock";
                                        if (item.Status == "Onaylandı") { bgClass = "bg-success text-white"; icon = "fa-check-circle"; }
                                        else if (item.Status == "Reddedildi") { bgClass = "bg-danger text-white"; icon = "fa-times-circle"; }
                                    }
                                    <span class="badge @bgClass px-3 py-2 rounded-pill shadow-sm">
                                        <i class="fas @icon me-1"></i> @item.Status
                                    </span>
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    @* ✅ Controller ile uyumlu "Details" linki *@
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm transition hover-up">
                                        <i class="fas fa-search me-1"></i> İncele
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-5 text-center">
                                <div class="opacity-50">
                                    <i class="fas fa-folder-open fa-3x mb-3 text-muted"></i>
                                    <p class="mb-0">Henüz bir başvuru mühürlenmemiş kardaşım.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary {
        background-color: rgba(67, 97, 238, 0.1);
    }

    .text-primary {
        color: #4361ee !important;
    }

    .transition {
        transition: all 0.3s ease;
    }

    .hover-up:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1) !important;
    }
</style>