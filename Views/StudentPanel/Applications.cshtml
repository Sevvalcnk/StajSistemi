@model IEnumerable<StajSistemi.Models.Internship>

<div class="container mt-4">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-dark text-white p-3">
            <h4 class="mb-0"><i class="fas fa-list-ul me-2"></i> Gelen Staj Başvuruları</h4>
        </div>
        <div class="card-body">
            <table class="table table-hover align-middle text-center">
                <thead class="table-light">
                    <tr>
                        <th>Öğrenci</th>
                        <th>Şirket Bilgisi</th>
                        <th>Departman</th>
                        <th>Durum</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @* ✅ MÜHÜR: Artık veriler AppUser tablosundan geliyor *@
                                    @if (item.AppUser != null)
                                    {
                                        <strong>@item.AppUser.FirstName @item.AppUser.LastName</strong>

                                        <br />
                                        <small class="text-muted">No: @item.AppUser.StudentNo</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Bilinmeyen Öğrenci</span>
                                    }
                                </td>
                                <td>
                                    @* ✅ Şirket Adı *@
                                    <strong>@item.CompanyName</strong>
                                </td>
                                <td>@item.Department?.DepartmentName</td> @* ✅ Departman adını nesneden çekmek daha güvenlidir *@
                                <td>
                                    @{
                                        var bgClass = "bg-warning text-dark";
                                        if (item.Status == "Onaylandı") bgClass = "bg-success text-white";
                                        else if (item.Status == "Reddedildi") bgClass = "bg-danger text-white";
                                    }
                                    <span class="badge @bgClass px-3 py-2">@item.Status</span>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill">
                                        <i class="fas fa-search me-1"></i> Detay
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-4 text-muted italic">Henüz bir başvuru bulunmuyor.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>