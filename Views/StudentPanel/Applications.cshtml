@using StajSistemi.Models @* 🛡️ Yeni etiketleri tanımak için bu mühür şart! *@
@model IEnumerable<StajSistemi.Models.InternshipApplication>

@{
    ViewData["Title"] = "Başvurularım";
}

<div class="container py-4 techNode-fade-in">
    @* --- 🛡️ ÜST BAŞLIK VE ÖZET KARTI --- *@
    <div class="glass-card p-4 shadow-lg border-0 rounded-4 bg-white mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h4 class="fw-bold mb-1 text-dark">
                    <i class="fas fa-file-signature text-primary me-2"></i>Staj Başvurularım
                </h4>
                <p class="text-muted small mb-0">Yaptığınız tüm başvuruların güncel durumunu buradan profesyonelce takip edebilirsiniz.</p>
            </div>
            <span class="badge bg-soft-primary text-primary rounded-pill px-4 py-2 border fw-bold">
                <i class="fas fa-paper-plane me-1"></i> Toplam: @(Model?.Count() ?? 0) Başvuru
            </span>
        </div>
    </div>

    @* --- 📋 BAŞVURU TABLOSU --- *@
    <div class="glass-card shadow-lg border-0 rounded-4 bg-white overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-primary text-white">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold">Şirket / Kurum</th>
                        <th class="py-3 text-uppercase small fw-bold text-center">Bölüm</th>
                        <th class="py-3 text-uppercase small fw-bold text-center">Başarı Skoru (4.00)</th> @* ✅ LİYAKAT GİTTİ, BAŞARI GELDİ *@
                        <th class="py-3 text-uppercase small fw-bold text-center">Başvuru Durumu</th>
                        <th class="pe-4 py-3 text-uppercase small fw-bold text-end">Detaylar</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="fw-bold text-dark">@(item.Internship?.CompanyName ?? "Belirtilmemiş")</div>
                                    <small class="text-muted"><i class="fas fa-map-marker-alt me-1"></i> @(item.Internship?.City?.Name ?? "Konum Bilgisi Yok")</small>
                                </td>
                                <td class="py-3 text-center">
                                    <span class="text-muted small">
                                        @(item.Internship?.Department?.DepartmentName ?? "Genel")
                                    </span>
                                </td>
                                <td class="py-3 text-center">
                                    @* ✅ BAŞARI SKORU DÖNÜŞÜMÜ: 285'i 2.85 yapıyoruz (100.0'e bölerek) *@
                                    @{
                                        double academicScore = item.SuccessScore / 100.0;
                                    }
                                    <div class="badge @(academicScore >= 3.0 ? "bg-success" : "bg-dark") text-white px-3 py-2 rounded-3 shadow-sm fw-bold">
                                        <i class="fas fa-graduation-cap me-1"></i> @academicScore.ToString("0.00")
                                    </div>
                                </td>
                                <td class="py-3 text-center">
                                    @if (item.Status == ApplicationStatus.Approved)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill fw-bold">
                                            <i class="fas fa-check-circle me-1"></i> Onaylandı
                                        </span>
                                    }
                                    else if (item.Status == ApplicationStatus.Rejected)
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 rounded-pill fw-bold">
                                            <i class="fas fa-times-circle me-1"></i> Sonuçlandı
                                        </span>
                                    }
                                    else if (item.Status == ApplicationStatus.InReview)
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2 rounded-pill fw-bold">
                                            <i class="fas fa-search me-1"></i> İnceleniyor
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-pill fw-bold text-dark">
                                            <i class="fas fa-clock me-1"></i> Beklemede
                                        </span>
                                    }
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-outline-primary btn-sm rounded-pill px-4 transition hover-up fw-bold">
                                        <i class="fas fa-eye me-1"></i> İncele
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="py-5 text-center">
                                <div class="opacity-50">
                                    <i class="fas fa-folder-open fa-3x mb-3 text-muted"></i>
                                    <p class="mb-0 fw-bold">Henüz aktif bir staj başvurunuz bulunmamaktadır.</p>
                                    <small>Yeni kariyer fırsatlarını keşfetmeye ne dersiniz? 😊</small>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary {
        background-color: rgba(67, 97, 238, 0.1);
    }

    .bg-success-subtle {
        background-color: #e8f5e9 !important;
    }

    .bg-danger-subtle {
        background-color: #ffebee !important;
    }

    .bg-warning-subtle {
        background-color: #fff9c4 !important;
    }

    .bg-info-subtle {
        background-color: #e3f2fd !important;
    }

    .transition {
        transition: all 0.3s ease;
    }

    .hover-up:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1) !important;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(67, 97, 238, 0.02);
    }
</style>