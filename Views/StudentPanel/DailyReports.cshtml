@model List<StajSistemi.Models.DailyReport>

@{
    ViewData["Title"] = "Staj Günlüklerim";
    Layout = "_Layout";
}

<div class="container py-5">
    @* --- ✍️ YENİ RAPOR EKLEME FORMU --- *@
    <div class="glass-card p-4 mb-5 shadow-sm">
        <h5 class="fw-bold mb-4 text-primary">
            <i class="fas fa-edit me-2"></i>Bugün Neler Yaptın?
        </h5>

        <form asp-action="AddDailyReport" method="post" enctype="multipart/form-data">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="small fw-bold text-muted">Staj Günü (1-30)</label>
                    <input type="number" name="DayNumber" class="form-control rounded-3" min="1" max="30" required placeholder="Örn: 12">
                </div>

                <div class="col-12">
                    <label class="small fw-bold text-muted">Çalışma Özeti</label>
                    <textarea name="Content" class="form-control rounded-4" rows="4" required
                              placeholder="Bugün hangi etkinliği yaptın veya hangi teknik sorunu çözdün? Detaylıca anlat kardaşım..."></textarea>
                </div>

                <div class="col-md-6">
                    <label class="small fw-bold text-muted">Etkinlik Fotoğrafı (Opsiyonel)</label>
                    <input type="file" name="activityPhoto" class="form-control rounded-pill border-dashed">
                    <small class="text-muted" style="font-size: 0.7rem;">Çocuklarla boyama, sunucu odası veya depo düzeni fotoğrafı mühürle! 📸</small>
                </div>

                <div class="col-12 text-end mt-3">
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
                        Raporu Sisteme Mühürle <i class="fas fa-paper-plane ms-2"></i>
                    </button>
                </div>
            </div>
        </form>
    </div>

    @* --- 📚 GEÇMİŞ RAPORLAR LİSTESİ --- *@
    <h5 class="fw-bold mb-4"><i class="fas fa-history text-warning me-2"></i>Geçmiş Günlüklerim</h5>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6">
                    <div class="glass-card p-4 hover-up h-100 border-start border-4 @(item.IsApproved ? "border-success" : "border-warning")">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                                <i class="fas fa-calendar-day me-1 text-primary"></i> @item.DayNumber. Gün
                            </span>
                            <small class="text-muted">@item.CreatedDate.ToString("dd MMMM yyyy")</small>
                        </div>

                        <p class="text-dark small mb-3" style="line-height: 1.6;">@item.Content</p>

                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <div class="rounded-4 overflow-hidden shadow-sm mb-3">
                                <img src="/uploads/reports/@item.ImagePath" class="img-fluid w-100" style="max-height: 200px; object-fit: cover;" alt="Staj Etkinliği">
                            </div>
                        }

                        <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                            <span class="small @(item.IsApproved ? "text-success fw-bold" : "text-muted italic")">
                                <i class="fas @(item.IsApproved ? "fa-check-double" : "fa-clock") me-1"></i>
                                @(item.IsApproved ? "Danışman Onayladı" : "Onay Bekliyor...")
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 glass-card opacity-75">
            <i class="fas fa-book-open fa-3x mb-3 text-muted"></i>
            <p class="text-muted">Henüz hiçbir günlük mühürlenmemiş. Hadi bismillah diyerek ilkini yaz! 🚀</p>
        </div>
    }
</div>