@model StajSistemi.DTOs.StudentDto
@{
    Layout = "_Layout";
    var activeApp = ViewBag.ActiveInternship as StajSistemi.Models.InternshipApplication;

    // ✅ MANY-TO-MANY GÜVENLİK VE LİYAKAT MÜHÜRÜ
    if (activeApp != null && activeApp.Internship != null)
    {
        if (activeApp.Internship.InternshipDepartments != null && activeApp.Internship.InternshipDepartments.Any())
        {
            if (!activeApp.Internship.InternshipDepartments.Any(d => d.DepartmentId == Model.DepartmentId))
            {
                activeApp = null;
            }
        }
    }

    var reports = ViewBag.DailyReports as List<StajSistemi.Models.DailyReport> ?? new List<StajSistemi.Models.DailyReport>();
    int totalDays = 30;
    bool isAdvisor = User.IsInRole("Advisor") || User.IsInRole("Admin");
}

<style>
    /* ✨ SİBER PREMIUM ESTETİK: Resmi A4 Standartı */
    body {
        background-color: #f1f5f9;
        font-family: 'Inter', sans-serif;
    }

    .staj-main-container {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 25px;
        padding: 40px 20px;
    }

    /* 🛠️ Sidebar (Akıllı Görünürlük) */
    .staj-sidebar {
        width: 300px;
        flex-shrink: 0;
        display: none;
    }

    .sidebar-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
    }

    .day-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
    }

    .day-item {
        aspect-ratio: 1;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
        color: #64748b;
        text-decoration: none;
        font-size: 10pt;
    }

        .day-item.filled {
            background: #dcfce7 !important;
            color: #15803d !important;
            border-color: #bbf7d0 !important;
        }

        .day-item.active {
            background: #4361ee !important;
            color: white !important;
            transform: scale(1.1);
            box-shadow: 0 5px 15px rgba(67, 97, 238, 0.3);
        }

    /* 📄 A4 BELGE ALANI */
    .document-content {
        width: 210mm;
        min-height: 297mm;
        background: white;
        padding: 25mm;
        box-shadow: 0 20px 50px rgba(0,0,0,0.08);
        border-radius: 4px;
        position: relative;
    }

    .nav-tabs-custom {
        border: none;
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 40px;
    }

        .nav-tabs-custom .nav-link {
            border: 1px solid #e2e8f0;
            border-radius: 50px;
            padding: 10px 30px;
            font-weight: 700;
            color: #64748b;
            background: #fff;
            transition: 0.3s;
        }

            .nav-tabs-custom .nav-link.active {
                background: #1e293b;
                color: white;
                border-color: #1e293b;
            }

    /* 🏛️ Resmi Başlıklar */
    .tc-baslik {
        text-align: center;
        margin-bottom: 25px;
        color: #000;
        line-height: 1.4;
    }

        .tc-baslik h5 {
            font-weight: 800;
            margin: 0;
            font-size: 14pt;
            text-transform: uppercase;
        }

        .tc-baslik .okul-ad {
            font-weight: 700;
            font-size: 12pt;
            margin-top: 5px;
            color: #334155;
        }

    .staj-ana-baslik {
        text-align: center;
        margin: 30px 0;
        font-size: 32pt;
        font-weight: 900;
        letter-spacing: 8px;
        border-top: 2px solid #000;
        border-bottom: 2px solid #000;
        padding: 12px 0;
        color: #000;
        font-family: 'Times New Roman', serif;
    }

    /* 📊 Tablo */
    .official-table {
        width: 100%;
        border-collapse: collapse;
        border: 2.5px solid #000;
        margin-top: 20px;
    }

        .official-table td {
            border: 1.5px solid #000;
            padding: 14px 20px;
            font-size: 11.5pt;
            font-family: 'Times New Roman', Times, serif;
            color: #000;
        }

    .label {
        font-weight: 900;
        background: #f8fafc;
        width: 40%;
        text-transform: uppercase;
    }

    /* 🖋️ Rapor Metin Alanı */
    .report-textarea {
        width: 100%;
        border: 1.5px solid #f1f5f9;
        border-radius: 15px;
        padding: 25px;
        min-height: 500px;
        font-size: 13pt;
        line-height: 1.8;
        font-family: 'Times New Roman', serif;
        background: #fafafa;
        outline: none;
        resize: none;
        transition: 0.3s;
    }

    #report-image-container {
        text-align: center;
        margin-top: 25px;
        display: none;
        padding: 15px;
        border: 1px dashed #cbd5e1;
        border-radius: 15px;
        background: #fcfcfc;
    }

    #report-image-preview {
        max-width: 95%;
        max-height: 350px;
        border-radius: 8px;
        border: 2px solid #fff;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    /* 🖨️ PDF YAZDIRMA MÜHÜRÜ (BOŞ SAYFALARI YOK EDER) */
    @@media print {
        html, body {
            height: auto !important;
            background: white !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .no-print, .staj-sidebar, .nav-tabs-custom, .navbar, #sidebar-wrapper {
            display: none !important;
        }

        .staj-main-container {
            display: block !important;
            padding: 0 !important;
            margin: 0 !important;
        }

        .document-content {
            display: none !important;
        }

        .print-only-pages {
            display: block !important;
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .page-break {
            display: block !important;
            page-break-after: always !important;
            background: white !important;
            padding: 15mm 20mm !important;
            min-height: 270mm !important; /* Boş sayfa engellemek için A4'ten küçük tutuldu */
            border: none !important;
            margin: 0 !important;
        }
            /* 🛡️ SİBER KRİTİK: En son sayfadan sonra sayfa sonu yapma */
            .page-break:last-child {
                page-break-after: auto !important;
                min-height: auto !important;
            }

        @@page {
            size: A4;
            margin: 0;
        }

        .pdf-report-img {
            max-width: 90%;
            max-height: 300px;
            margin-top: 15px;
            border: 1px solid #000;
            padding: 5px;
        }
    }

    .print-only-pages {
        display: none;
    }
</style>

<div class="staj-main-container">
    @* --- 🛠️ SOL PANEL --- *@
    <div class="staj-sidebar no-print" id="sidebarSelector">
        <div class="sidebar-card">
            <h6 class="fw-bold text-uppercase small mb-4" style="color: #4361ee; letter-spacing: 1px;"><i class="fas fa-layer-group me-2"></i>İŞ GÜNÜ SEÇİMİ</h6>
            <div class="day-grid">
                @for (int i = 1; i <= totalDays; i++)
                {
                    var isFilled = reports.Any(r => r.DayNumber == i);
                    <a href="javascript:void(0)" onclick="loadDay(@i)" id="btn-day-@i" class="day-item @(isFilled ? "filled" : "")">@i</a>
                }
            </div>
            @if (isAdvisor)
            {
                <button onclick="window.print()" class="btn btn-danger w-100 mt-5 rounded-pill fw-bold py-3 shadow-lg">
                    <i class="fas fa-file-pdf me-2"></i> PDF ÇIKTI AL
                </button>
            }
        </div>
    </div>

    @* --- 📄 EKRAN GÖRÜNÜMÜ --- *@
    <div class="document-content no-print animate__animated animate__fadeIn">
        <ul class="nav nav-tabs nav-tabs-custom" id="stajTab">
            <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#kapak" type="button" onclick="toggleSidebar(false)">📙 Dosya Kapağı</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#raporlar" type="button" onclick="toggleSidebar(true)">📝 Günlük Raporlar</button></li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="kapak">
                <div class="tc-baslik">
                    <h5>T.C.</h5>
                    <h5>@Model.UniversityName.ToUpper()</h5>
                    <div class="okul-ad">@(Model.FacultyName?.ToUpper() ?? "AYANCIK MESLEK YÜKSEKOKULU")</div>
                </div>
                <div class="staj-ana-baslik">STAJ DEFTERİ</div>
                <table class="official-table">
                    <tr><td class="label">ÖĞRENCİ ADI SOYADI</td><td class="fw-bold">@Model.Name.ToUpper() @Model.Surname.ToUpper()</td></tr>
                    <tr><td class="label">ÖĞRENCİ NUMARASI</td><td class="fw-bold">@Model.StudentNo</td></tr>
                    <tr><td class="label">BÖLÜMÜ / PROGRAMI</td><td>@Model.DepartmentName</td></tr>
                    <tr><td class="label">AKADEMİK YIL / SINIF</td><td>@Model.AcademicYear</td></tr>
                    <tr><td class="label">STAJ YAPILAN KURUM</td><td>@(activeApp?.Internship?.CompanyName ?? "BELİRTİLMEMİŞ")</td></tr>
                    <tr><td class="label">STAJ BAŞLANGIÇ TARİHİ</td><td>@(activeApp?.Internship?.StartDate.ToString("dd.MM.yyyy") ?? "---")</td></tr>
                    <tr><td class="label">STAJ BİTİŞ TARİHİ</td><td>@(activeApp?.Internship?.EndDate.ToString("dd.MM.yyyy") ?? "---")</td></tr>
                    <tr><td class="label">TOPLAM İŞ GÜNÜ</td><td>@totalDays İŞ GÜNÜ</td></tr>
                </table>
                <div class="mt-5 pt-5 row text-center" style="font-size: 10pt;">
                    <div class="col-4">Öğrenci İmzası<br />...........</div>
                    <div class="col-4">Kurum Onayı (Kaşe)<br />...........</div>
                    <div class="col-4">Danışman Onayı<br />...........</div>
                </div>
            </div>

            <div class="tab-pane fade" id="raporlar">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <h4 class="fw-bold mb-0 text-dark"><span id="display-day-number" class="text-primary">1</span>. GÜN FAALİYET RAPORU</h4>
                    <span id="display-report-date" class="badge bg-light text-muted border px-3 py-2 rounded-pill">Henüz Kayıt Yok</span>
                </div>
                <form asp-action="SaveDailyReport" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="dayNumber" id="input-day-number" value="1" />
                    <textarea name="content" id="report-content" class="report-textarea" placeholder="Teknik çalışmalarınızı profesyonel bir dille buraya mühürleyin..." @(isAdvisor ? "readonly" : "")></textarea>
                    <div id="report-image-container">
                        <label class="small fw-bold text-muted d-block mb-2">GÜNÜN TEKNİK GÖRSELİ</label>
                        <img id="report-image-preview" src="" alt="Rapor Görseli" />
                    </div>
                    @if (!isAdvisor)
                    {
                        <div class="mt-4 no-print bg-light p-4 rounded-4 d-flex justify-content-between align-items-center shadow-sm">
                            <div class="flex-grow-1 me-3">
                                <label class="small fw-bold text-muted mb-2">Görsel veya Kanıt Yükle</label>
                                <input type="file" name="reportImage" class="form-control border-0" />
                            </div>
                            <button type="submit" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-lg">GÜNÜ MÜHÜRLE</button>
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

@* 🖨️ YAZDIRMA ALANI (1 KAPAK + 30 GÜN) *@
<div class="print-only-pages">
    @* KAPAK *@
    <div class="page-break">
        <div class="tc-baslik">
            <h5>T.C.</h5>
            <h5>@Model.UniversityName.ToUpper()</h5>
            <div class="okul-ad">@(Model.FacultyName?.ToUpper() ?? "AYANCIK MESLEK YÜKSEKOKULU")</div>
        </div>
        <div class="staj-ana-baslik">STAJ DEFTERİ</div>
        <table class="official-table">
            <tr><td class="label">ÖĞRENCİ ADI SOYADI</td><td>@Model.Name.ToUpper() @Model.Surname.ToUpper()</td></tr>
            <tr><td class="label">ÖĞRENCİ NUMARASI</td><td>@Model.StudentNo</td></tr>
            <tr><td class="label">BÖLÜMÜ / PROGRAMI</td><td>@Model.DepartmentName</td></tr>
            <tr><td class="label">AKADEMİK YIL / SINIF</td><td>@Model.AcademicYear</td></tr>
            <tr><td class="label">STAJ YAPILAN KURUM</td><td>@(activeApp?.Internship?.CompanyName ?? "---")</td></tr>
            <tr><td class="label">STAJ BAŞLANGIÇ TARİHİ</td><td>@(activeApp?.Internship?.StartDate.ToString("dd.MM.yyyy") ?? "---")</td></tr>
            <tr><td class="label">STAJ BİTİŞ TARİHİ</td><td>@(activeApp?.Internship?.EndDate.ToString("dd.MM.yyyy") ?? "---")</td></tr>
            <tr><td class="label">TOPLAM İŞ GÜNÜ</td><td>@totalDays GÜN</td></tr>
        </table>
        <div class="row text-center" style="margin-top: 130px;">
            <div class="col-4">Öğrenci İmzası<br />.......</div>
            <div class="col-4">Kurum Onayı (Kaşe)<br />.......</div>
            <div class="col-4">Danışman Onayı<br />.......</div>
        </div>
    </div>

    @* 30 GÜN *@
    @for (int i = 1; i <= totalDays; i++)
    {
        var r = reports.FirstOrDefault(x => x.DayNumber == i);
        <div class="page-break">
            <div class="tc-baslik"><h6>@Model.UniversityName.ToUpper() - STAJ DEFTERİ</h6></div>
            <hr style="border: 0.5px solid #000;" />
            <div class="d-flex justify-content-between my-2" style="font-size: 10pt;">
                <p><strong>İŞ GÜNÜ:</strong> @i</p>
                <p><strong>TARİH:</strong> @(r?.CreatedDate.ToString("dd.MM.yyyy") ?? "---")</p>
            </div>
            <div style="min-height: 400px; font-size: 11pt; line-height: 1.8; white-space: pre-wrap; font-family: 'Times New Roman', serif; border: 1px solid #eee; padding: 15px; margin-bottom: 20px;">
                @(r?.Content ?? "Bu güne ait bir faaliyet kaydı girilmemiştir.")
            </div>
            @if (r != null && !string.IsNullOrEmpty(r.ImagePath))
            {
                <div class="text-center"><img src="/uploads/reports/@r.ImagePath" class="pdf-report-img" /></div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        const rawReports = @Html.Raw(Json.Serialize(reports.Select(r => new { dayNumber = r.DayNumber, content = r.Content, createdDate = r.CreatedDate, imagePath = r.ImagePath })));
        function toggleSidebar(show) { if(show) { $('#sidebarSelector').fadeIn(); } else { $('#sidebarSelector').fadeOut(); } }
        function loadDay(day) {
            $(".day-item").removeClass("active"); $("#btn-day-" + day).addClass("active");
            $("#display-day-number").text(day); $("#input-day-number").val(day);
            const r = rawReports.find(x => x.dayNumber === day);
            const imgBox = document.getElementById('report-image-container');
            const imgPrev = document.getElementById('report-image-preview');
            if (r) {
                $("#report-content").val(r.content);
                $("#display-report-date").text("Kayıt: " + new Date(r.createdDate).toLocaleDateString('tr-TR'));
                if (r.imagePath) { imgPrev.src = "/uploads/reports/" + r.imagePath; imgBox.style.display = "block"; } else { imgBox.style.display = "none"; }
            } else {
                $("#report-content").val(""); $("#display-report-date").text("Kayıt Yok"); imgBox.style.display = "none";
            }
        }
        $(document).ready(function() { toggleSidebar(false); loadDay(1); });
    </script>
}