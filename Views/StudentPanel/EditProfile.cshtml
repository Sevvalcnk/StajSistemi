@model StajSistemi.DTOs.StudentDto

@{
    ViewData["Title"] = "Profil Bilgilerini Güncelle";
}

<style>
    body {
        background-color: #f8faff;
        background-image: radial-gradient(at 0% 0%, rgba(37, 140, 251, 0.05) 0, transparent 50%), radial-gradient(at 100% 100%, rgba(118, 75, 162, 0.05) 0, transparent 50%), radial-gradient(#d1d8e0 0.5px, transparent 0.5px);
        background-size: 100% 100%, 100% 100%, 30px 30px;
        background-attachment: fixed;
    }

    .card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
    }

    .input-focus:focus {
        border-color: #2c3e50 !important;
        box-shadow: 0 0 10px rgba(44, 62, 80, 0.1) !important;
    }

    .border-dashed {
        border-style: dashed !important;
    }
</style>

<div class="container py-5 techNode-fade-in">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white text-center py-4">
                    <h3 class="fw-bold mb-0"><i class="fas fa-user-edit me-2"></i>Kariyer Profilini Güncelle</h3>
                </div>
                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="EditProfile" method="post" enctype="multipart/form-data" id="profileEditForm">
                        @Html.AntiForgeryToken()

                        @* 🛡️ GİZLİ ALANLAR *@
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="StudentNo" />

                        <div class="mb-4 text-center">
                            <img src="https://ui-avatars.com/api/?name=@(Model.Name)+@(Model.Surname)&background=2c3e50&color=fff&size=100"
                                 class="rounded-circle shadow-sm mb-2" alt="Avatar">
                            <p class="text-muted small mb-0">@Model.Email</p>
                            <span class="badge bg-light text-dark border">No: @Model.StudentNo</span>
                        </div>

                        @* 👤 TEMEL BİLGİLER *@
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-bold text-muted small text-uppercase">Adınız</label>
                                <input asp-for="Name" class="form-control rounded-pill border-2 input-focus" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Surname" class="form-label fw-bold text-muted small text-uppercase">Soyadınız</label>
                                <input asp-for="Surname" class="form-control rounded-pill border-2 input-focus" />
                            </div>
                        </div>

                        @* 🎓 EĞİTİM DÜZEYİ VE ÜNİVERSİTE *@
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="DegreeType" class="form-label fw-bold text-muted small text-uppercase">Eğitim Düzeyi</label>
                                <select asp-for="DegreeType" class="form-select rounded-pill border-2 input-focus" id="degreeSelect">
                                    <option value="Lisans">Lisans (4 Yıllık)</option>
                                    <option value="Önlisans">Önlisans (2 Yıllık)</option>
                                </select>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="UniversityName" class="form-label fw-bold text-muted small text-uppercase">Üniversite Adı</label>
                                <input asp-for="UniversityName" class="form-control rounded-pill border-2 input-focus" placeholder="Örn: Niğde Üniversitesi" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label id="facultyLabel" class="form-label fw-bold text-muted small text-uppercase">
                                    @(Model.DegreeType == "Önlisans" ? "Meslek Yüksekokulu" : "Fakülte Adı")
                                </label>
                                <input asp-for="FacultyName" class="form-control rounded-pill border-2 input-focus" placeholder="Birim adını yazınız" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DepartmentId" class="form-label fw-bold text-muted small text-uppercase">Okuduğunuz Bölüm</label>
                            <select asp-for="DepartmentId" class="form-select rounded-pill border-2 input-focus"
                                    asp-items="ViewBag.Departments">
                                <option value="">--- Bölümünüzü Seçiniz ---</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CityId" class="form-label fw-bold text-muted small text-uppercase">Yaşadığınız Şehir</label>
                            <select asp-for="CityId" class="form-select rounded-pill border-2 input-focus"
                                    asp-items="ViewBag.Cities">
                                <option value="">--- Şehir Seçiniz ---</option>
                            </select>
                        </div>

                        @* 👶 DOĞUM VE AKADEMİK BİLGİLER *@
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="BirthPlace" class="form-label fw-bold text-muted small text-uppercase">Doğum Yeri</label>
                                <input asp-for="BirthPlace" class="form-control rounded-pill border-2 input-focus" placeholder="Şehir" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="BirthDate" class="form-label fw-bold text-muted small text-uppercase">Doğum Tarihi</label>
                                <input asp-for="BirthDate" type="date" class="form-control rounded-pill border-2 input-focus" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="AcademicYear" class="form-label fw-bold text-muted small text-uppercase">Akademik Yıl</label>
                                <input asp-for="AcademicYear" class="form-control rounded-pill border-2 input-focus" placeholder="2025-2029" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-bold text-muted small text-uppercase">Telefon</label>
                                <input asp-for="PhoneNumber" class="form-control rounded-pill border-2 input-focus" placeholder="05XX..." />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="GPA" class="form-label fw-bold text-muted small text-uppercase">GPA (Not Ort. Max: 4.00)</label>
                                @* 🛡️ MÜHÜR: GPA KRİZİNİ BİTİREN KİLİT *@
                                <input asp-for="GPA" type="number" step="0.01" min="0" max="4.00"
                                       class="form-control rounded-pill border-2 input-focus"
                                       placeholder="Örn: 3.50" required id="GPAInput" />
                                <span asp-validation-for="GPA" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EducationSummary" class="form-label fw-bold text-muted small text-uppercase">Eğitim Özeti</label>
                            <input asp-for="EducationSummary" class="form-control rounded-pill border-2 input-focus" placeholder="Örn: 3. Sınıf Öğrencisi" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="PersonalSkills" class="form-label fw-bold text-muted small text-uppercase">Yetenekler</label>
                            <textarea asp-for="PersonalSkills" class="form-control rounded-4 border-2 input-focus" rows="3" placeholder="C#, SQL, Office..."></textarea>
                        </div>

                        <hr class="my-4">

                        @* DOSYA YÜKLEME ALANLARI *@
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="p-3 border-2 border-dashed rounded-4 bg-light text-center h-100 shadow-sm">
                                    <i class="fas fa-file-pdf text-danger mb-2 fa-2x"></i>
                                    <label class="d-block fw-bold small text-uppercase mb-2">CV Yükle (PDF/Word)</label>
                                    <input type="file" name="CVFile" id="CVFile" class="form-control form-control-sm rounded-pill" accept=".pdf,.doc,.docx" />
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="p-3 border-2 border-dashed rounded-4 bg-light text-center h-100 shadow-sm">
                                    <i class="fas fa-award text-warning mb-2 fa-2x"></i>
                                    <label class="d-block fw-bold small text-uppercase mb-2">Sertifikalar (PDF/Resim/Word)</label>
                                    <input type="file" name="CertificateFile" id="CertificateFile" class="form-control form-control-sm rounded-pill" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" />
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow">
                                <i class="fas fa-save me-2"></i>Değişiklikleri Mühürle
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted mt-2 text-decoration-none text-center">
                                Vazgeç ve Geri Dön
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // ✅ SİHİRLİ ETİKET DEĞİŞTİRİCİ
        document.getElementById('degreeSelect').addEventListener('change', function() {
            const label = document.getElementById('facultyLabel');
            label.innerText = this.value === "Önlisans" ? "Meslek Yüksekokulu" : "Fakülte Adı";
        });

        document.getElementById('profileEditForm').onsubmit = function (e) {
            const gpaInput = document.getElementById('GPAInput');
            const izinliCV = /(\.pdf|\.doc|\.docx)$/i;
            const izinliSertifika = /(\.pdf|\.doc|\.docx|\.jpg|\.jpeg|\.png)$/i;

            // 🛡️ GPA SİBER KALKANI: 4'ten büyükse durdur!
            if (parseFloat(gpaInput.value.replace(',', '.')) > 4.00) {
                alert("❌ Hata: Akademik ortalama (GPA) 4.00'den büyük olamaz!\nLütfen geçerli bir not giriniz (Örn: 2.80).");
                gpaInput.focus();
                e.preventDefault();
                return false;
            }

            const cvInput = document.getElementById('CVFile');
            const certInput = document.getElementById('CertificateFile');

            if (cvInput.files.length > 0) {
                if (!izinliCV.exec(cvInput.files[0].name)) {
                    alert("❌ Hata: Uygun olmayan CV formatı!\nLütfen sadece PDF veya Word belgesi seçiniz.");
                    e.preventDefault();
                    return false;
                }
            }

            if (certInput.files.length > 0) {
                if (!izinliSertifika.exec(certInput.files[0].name)) {
                    alert("❌ Hata: Uygun olmayan Sertifika formatı!\nLütfen PDF, Word veya Resim (JPG/PNG) seçiniz.");
                    e.preventDefault();
                    return false;
                }
            }
            return true;
        };
    </script>
}