@model StajSistemi.DTOs.StudentDto

@{
    ViewData["Title"] = "Öğrenci Kariyer Merkezi";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --primary-blue: #4361ee;
        --soft-bg: #f8faff;
        --card-shadow: 0 10px 30px rgba(67, 97, 238, 0.05);
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--soft-bg);
        color: #2b2d42;
    }

    .glass-card {
        background: white;
        border: none;
        border-radius: 24px;
        box-shadow: var(--card-shadow);
        transition: all 0.3s ease;
    }

    .hover-up:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
    }

    /* --- 🎡 STAJ YOL HARİTASI --- */
    .timeline-steps {
        display: flex;
        justify-content: space-between;
        position: relative;
        margin-bottom: 2rem;
    }

        .timeline-steps::after {
            content: "";
            position: absolute;
            top: 18px;
            left: 0;
            right: 0;
            height: 3px;
            background: #e0e6ed;
            z-index: 1;
        }

    .step-item {
        position: relative;
        z-index: 2;
        text-align: center;
        width: 25%;
    }

    .step-icon {
        width: 40px;
        height: 40px;
        background: white;
        border: 3px solid #e0e6ed;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 10px;
        transition: 0.3;
    }

    .step-item.active .step-icon {
        border-color: var(--primary-blue);
        color: var(--primary-blue);
        box-shadow: 0 0 15px rgba(67, 97, 238, 0.3);
    }

    .step-label {
        font-size: 0.75rem;
        color: #8d99ae;
        font-weight: 600;
    }

    /* --- 💬 DASHBOARD MESAJ ÖNİZLEME --- */
    .chat-bubble-preview {
        background: #f8faff;
        border-radius: 15px;
        padding: 12px 15px;
        margin-bottom: 10px;
        border-left: 4px solid var(--primary-blue);
        transition: 0.2s;
    }

        .chat-bubble-preview:hover {
            background: #f1f3f9;
        }

    .profile-img {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 35px;
        border: 5px solid white;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .gpa-badge {
        position: absolute;
        bottom: -5px;
        right: -5px;
        background: #2ecc71;
        color: white;
        padding: 5px 12px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.8rem;
        border: 3px solid white;
    }

    .chat-scroll-area {
        max-height: 400px;
        overflow-y: auto;
        padding-right: 10px;
    }
</style>

<div class="container py-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 rounded-4 shadow-sm mb-4">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    @* --- STAJ SÜRECİ --- *@
    <div class="glass-card p-4 mb-5 shadow-sm">
        <h6 class="fw-bold mb-4 text-uppercase text-muted small" style="letter-spacing: 1px;">Staj Süreci Takip Çizelgesi</h6>
        <div class="timeline-steps">
            <div class="step-item active"><div class="step-icon"><i class="fas fa-file-alt"></i></div><div class="step-label">Başvuru</div></div>
            <div class="step-item active"><div class="step-icon"><i class="fas fa-user-check"></i></div><div class="step-label">Onay</div></div>
            <div class="step-item"><div class="step-icon"><i class="fas fa-briefcase"></i></div><div class="step-label">Stajda</div></div>
            <div class="step-item"><div class="step-icon"><i class="fas fa-flag-checkered"></i></div><div class="step-label">Bitiş</div></div>
        </div>
    </div>

    <div class="row">
        @* --- SOL TARAF: PROFİL ÖZETİ --- *@
        <div class="col-lg-4">
            <div class="glass-card p-4 text-center mb-4 sticky-top" style="top: 20px;">
                <div class="position-relative d-inline-block mb-3">
                    <img src="https://ui-avatars.com/api/?name=@(Model.Name)+@(Model.Surname)&background=4361ee&color=fff&size=200" class="profile-img">
                    <div class="gpa-badge">@Model.GPA</div>
                </div>
                <h4 class="fw-bold mb-1">@Model.Name @Model.Surname</h4>
                <p class="text-muted small">@Model.Email</p>

                <div class="text-start border-top pt-4 mb-4">
                    <small class="text-muted d-block fw-bold text-uppercase mb-1" style="font-size: 0.65rem;">Eğitim Bilgisi</small>
                    <span class="small fw-bold">@(Model.EducationSummary ?? "İnternet ve Ağ Teknolojileri")</span>
                </div>

                <div class="d-grid gap-2">
                    <a asp-action="EditProfile" class="btn btn-primary rounded-pill fw-bold py-2 shadow-sm">
                        <i class="fas fa-user-edit me-2"></i> Profili Güncelle
                    </a>
                </div>
            </div>
        </div>

        @* --- SAĞ TARAF: TAVSİYELER VE EŞLEŞMELER --- *@
        <div class="col-lg-8">
            <div class="glass-card p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0"><i class="fas fa-comments text-primary me-2"></i>Danışman Tavsiyeleri</h5>
                    @* ✅ ESAS PROFESYONEL SAYFAYA GİDEN MÜHÜRLÜ BUTON *@
                    <a asp-controller="Chat" asp-action="Index" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                        Tümünü Gör / Mesajlaş <i class="fas fa-external-link-alt ms-1"></i>
                    </a>
                </div>

                <div class="chat-scroll-area">
                    @if (ViewBag.StudentMessages != null && ((List<StajSistemi.Models.ChatMessage>)ViewBag.StudentMessages).Any())
                    {
                        foreach (var msg in (List<StajSistemi.Models.ChatMessage>)ViewBag.StudentMessages)
                        {
                            <div class="chat-bubble-preview shadow-sm">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-bold small text-primary">@msg.Sender?.FullName</span>
                                    <span class="text-muted" style="font-size: 0.65rem;">@msg.SentDate.ToString("dd.MM HH:mm")</span>
                                </div>
                                <p class="small mb-0 text-dark">@msg.Content</p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 opacity-50">
                            <i class="fas fa-comment-slash fa-2x mb-2"></i>
                            <p class="small">Henüz bir mesaj mühürlenmemiş.</p>
                        </div>
                    }
                </div>
            </div>

            <div class="glass-card p-4">
                <h5 class="fw-bold mb-4"><i class="fas fa-brain text-warning me-2"></i>Akıllı Staj Eşleşmeleri</h5>
                @if (ViewBag.SmartMatches != null)
                {
                    <div class="row g-3">
                        @foreach (var match in ViewBag.SmartMatches)
                        {
                            <div class="col-12">
                                <div class="card border-0 bg-light rounded-4 hover-up p-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="fw-bold mb-1">@match.Ilan.CompanyName</h6>
                                            <span class="badge bg-success rounded-pill" style="font-size: 0.7rem;">%@match.Score Uyum</span>
                                        </div>
                                        <a asp-controller="Internship" asp-action="Apply" asp-route-id="@match.Ilan.Id" class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-bold">Başvur</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var chatArea = document.getElementById("chatArea");
            if (chatArea) { chatArea.scrollTop = chatArea.scrollHeight; }
        });
    </script>
}