@model StajSistemi.DTOs.StudentDto
@{
    ViewData["Title"] = "Staj Dashboard";
    var appliedIds = ViewBag.AppliedInternshipIds as List<int> ?? new List<int>();
    // 🛡️ MÜHÜR: Çizelge için aktif başvuruyu Controller'dan çekiyoruz
    var timelineApp = ViewBag.ActiveAppForTimeline as StajSistemi.Models.InternshipApplication;

    // 🛡️ ADIM 1: Giren kişinin hoca mı yoksa öğrenci mi olduğunu anlayan siber kilit
    bool isAdvisor = User.IsInRole("Advisor") || User.IsInRole("Admin");
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
        background-color: #f3f6f9;
        font-family: 'Inter', sans-serif;
    }

    .centered-container {
        max-width: 1250px;
        margin: 0 auto;
        padding: 30px 15px;
    }

    /* 👤 PROFİL KARTI */
    .profile-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        padding: 25px;
        text-align: center;
        border: none;
    }

    .profile-img {
        width: 100px;
        height: 100px;
        border-radius: 30px;
        border: 4px solid white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        object-fit: cover;
    }

    /* 📊 TABLO TASARIMI */
    .staj-list-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        padding: 25px;
        border: none;
    }

    .staj-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

    .staj-row td {
        padding: 18px 15px;
        vertical-align: middle;
        background: #ffffff;
        border-top: 1px solid #f1f5f9;
        border-bottom: 1px solid #f1f5f9;
        transition: 0.3s;
    }

        .staj-row td:first-child {
            border-left: 1px solid #f1f5f9;
            border-radius: 15px 0 0 15px;
        }

        .staj-row td:last-child {
            border-right: 1px solid #f1f5f9;
            border-radius: 0 15px 15px 0;
        }

    .staj-row:hover td {
        background-color: #f8fafc;
        transform: scale(1.005);
    }

    .badge-program {
        background: #e0f2fe;
        color: #0369a1;
        padding: 8px 14px;
        border-radius: 10px;
        font-size: 0.72rem;
        font-weight: 700;
        border: 1px solid #bae6fd;
        white-space: nowrap;
        display: inline-block;
    }

    .date-text {
        font-size: 0.85rem;
        color: #475569;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-staj-apply {
        background-color: #3b82f6;
        color: white;
        border-radius: 12px;
        padding: 8px 22px;
        font-weight: 700;
        font-size: 0.82rem;
        border: none;
        transition: 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-staj-apply:hover {
            background-color: #1d4ed8;
            color: white;
            box-shadow: 0 5px 15px rgba(59, 130, 246, 0.3);
        }

    .btn-applied-success {
        background-color: #10b981;
        color: white;
        border-radius: 12px;
        padding: 8px 22px;
        font-weight: 700;
        font-size: 0.82rem;
        border: none;
        cursor: default;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    /* 🛡️ ÇİZELGE ÖZEL STİLLERİ */
    .timeline-dot {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 2;
        transition: 0.3s;
    }

    .timeline-line {
        height: 2px;
        background: #e9ecef;
        position: absolute;
        top: 22px;
        left: 0;
        right: 0;
        z-index: 1;
    }
</style>

<div class="centered-container">
    <div class="row g-4">
        @* --- 👤 SOL: PROFİL ÖZETİ --- *@
        <div class="col-xl-3 col-lg-4">
            <div class="profile-card sticky-top" style="top: 20px;">
                <div class="position-relative d-inline-block mb-3">
                    <img src="https://ui-avatars.com/api/?name=@(Model.Name)+@(Model.Surname)&background=4361ee&color=fff" class="profile-img">
                    <div class="badge bg-success position-absolute" style="bottom: 0; right: 0; border-radius: 10px; border: 3px solid white; padding: 5px 10px;">
                        @(ViewBag.TotalScore ?? 350)
                    </div>
                </div>
                <h5 class="fw-bold mb-1">@Model.Name @Model.Surname</h5>
                <p class="text-muted small border-bottom pb-3">@Model.Email</p>
                <div class="text-start small">
                    <label class="text-muted fw-bold text-uppercase" style="font-size: 0.6rem;">Üniversite</label>
                    <p class="fw-bold text-primary mb-2">@Model.UniversityName</p>
                    <label class="text-muted fw-bold text-uppercase" style="font-size: 0.6rem;">Program</label>
                    <p class="fw-bold text-success">@Model.DepartmentName</p>
                </div>

                @* 🛡️ GÜVENLİK MÜHÜRÜ: Hoca profil güncelleyemez *@
                @if (!isAdvisor)
                {
                    <a asp-action="EditProfile" class="btn btn-primary w-100 rounded-pill mt-3 py-2 btn-sm fw-bold">Profili Güncelle</a>
                }
                else
                {
                    <div class="alert alert-info py-2 small mt-3 rounded-pill fw-bold border-0" style="font-size: 10px;">
                        <i class="fas fa-eye me-1"></i> GÖZETİM MODU AKTİF
                    </div>
                }
            </div>
        </div>

        @* --- 📊 SAĞ: İÇERİK ALANI --- *@
        <div class="col-xl-9 col-lg-8">

            @* 🛡️ MÜHÜR: STAJ SÜRECİ TAKİP ÇİZELGESİ *@
            @if (timelineApp != null)
            {
                <div class="card shadow-sm border-0 rounded-4 mb-4 animate__animated animate__fadeInDown">
                    <div class="card-body p-4">
                        <h6 class="fw-bold text-muted text-uppercase mb-4" style="font-size: 0.72rem; letter-spacing: 1px;">
                            <i class="fas fa-project-diagram text-primary me-2"></i>Staj Süreci Takip Çizelgesi
                        </h6>
                        <div class="position-relative d-flex justify-content-between">
                            <div class="timeline-line"></div>

                            <div class="text-center" style="width: 25%;">
                                <div class="timeline-dot bg-primary text-white mx-auto shadow">
                                    <i class="fas fa-file-alt"></i>
                                </div>
                                <p class="small fw-bold mt-2 mb-0">Başvuru</p>
                                <small class="text-muted" style="font-size: 10px;">@timelineApp.ApplicationDate.ToString("dd.MM.yyyy")</small>
                            </div>

                            <div class="text-center" style="width: 25%;">
                                <div class="timeline-dot @(timelineApp.Status == ApplicationStatus.Approved || timelineApp.Status == ApplicationStatus.Rejected ? "bg-primary text-white shadow" : "bg-white border text-muted") mx-auto">
                                    <i class="fas fa-user-check"></i>
                                </div>
                                <p class="small fw-bold mt-2 mb-0">Onay</p>
                            </div>

                            <div class="text-center" style="width: 25%;">
                                <div class="timeline-dot @(timelineApp.Status == ApplicationStatus.Approved ? "bg-primary text-white shadow" : "bg-white border text-muted") mx-auto">
                                    <i class="fas fa-briefcase"></i>
                                </div>
                                <p class="small fw-bold mt-2 mb-0">Stajda</p>
                            </div>

                            <div class="text-center" style="width: 25%;">
                                <div class="timeline-dot bg-white border text-muted mx-auto">
                                    <i class="fas fa-flag-checkered"></i>
                                </div>
                                <p class="small fw-bold mt-2 mb-0">Bitiş</p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* --- İLANLAR LİSTESİ --- *@
            <div class="staj-list-card animate__animated animate__fadeIn">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0 text-dark"><i class="fas fa-briefcase text-primary me-2"></i>Aktif Staj İlanları</h5>
                    <a asp-action="Index" asp-route-filter="all" class="btn btn-sm btn-outline-secondary rounded-pill px-3">Tüm İlanlar</a>
                </div>

                <div class="table-responsive">
                    <table class="staj-table">
                        <thead>
                            <tr class="text-muted small fw-bold">
                                <th style="width: 35%;">İLAN BİLGİSİ</th>
                                <th style="width: 25%;">HEDEF BÖLÜM</th>
                                <th style="width: 20%;">TARİH</th>
                                <th class="text-center" style="width: 10%;">KONTENJAN</th>
                                <th class="text-center" style="width: 10%;">İŞLEMLER</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.SmartMatches != null)
                            {
                                foreach (dynamic match in ViewBag.SmartMatches)
                                {
                                    <tr class="staj-row">
                                        <td>
                                            <div class="fw-bold text-dark">@match.Ilan.CompanyName Staj İlanı</div>
                                            <div class="text-muted" style="font-size:0.75rem;">@match.Ilan.City?.Name</div>
                                        </td>
                                        <td>
                                            <span class="badge-program">
                                                <i class="fas fa-graduation-cap me-1"></i> @match.Ilan.Department.DepartmentName
                                            </span>
                                        </td>
                                        <td>
                                            <div class="date-text"><i class="far fa-calendar-alt text-primary"></i> 20.04.2026</div>
                                            <div class="date-text text-muted mt-1" style="font-size:0.7rem;"><i class="fas fa-arrow-down ms-1 me-2"></i> 19.06.2026</div>
                                        </td>
                                        <td class="text-center">
                                            <span class="fw-extrabold text-primary h5 mb-0">@((match.Ilan.Id % 3) + 1)</span>
                                        </td>
                                        <td class="text-center">
                                            @if (appliedIds.Contains(match.Ilan.Id))
                                            {
                                                <button class="btn-applied-success"><i class="fas fa-check-circle"></i> Başvuruldu</button>
                                            }
                                            else
                                            {
                                                @* 🛡️ GÜVENLİK MÜHÜRÜ: Hoca öğrenci adına başvuru butonu göremez *@
                                                @if (!isAdvisor)
                                                {
                                                    <a asp-action="Apply" asp-route-id="@match.Ilan.Id" class="btn-staj-apply">
                                                        <i class="fas fa-paper-plane"></i> Başvur
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-muted p-2" style="font-size: 9px; border: 1px solid #eee;">İnceleme Modu</span>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["AlreadyApplied"] != null)
        {
            <text>
                    Swal.fire({
                        title: 'Mükerrer Başvuru! 🛡️',
                        text: "Bu ilana daha önce başvuruda bulundunuz. Başvurunuz sistemde kayıtlıdır.",
                        icon: 'info',
                        confirmButtonColor: '#4361ee',
                        borderRadius: '15px'
                    });
            </text>
        }

        @if (TempData["DeptMismatch"] != null)
        {
            <text>
                    Swal.fire({
                        title: 'Program Uyuşmazlığı! 🛡️',
                        text: "Seçtiğiniz ilan programınızla tam uyumlu görünmüyor. Bölümünüze uygun ilanları listelemek ister misiniz?",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#4361ee',
                        cancelButtonColor: '#ef4444',
                        confirmButtonText: '✅ Evet, Uygunları Gör',
                        borderRadius: '15px'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = '@Url.Action("Index", "StudentPanel", new { filter = "suitable" })';
                        }
                    });
            </text>
        }
    </script>
}