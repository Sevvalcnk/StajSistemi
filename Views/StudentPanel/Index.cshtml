@model StajSistemi.DTOs.StudentDto
@{
    ViewData["Title"] = "Staj Dashboard";
    var appliedIds = ViewBag.AppliedInternshipIds as List<int> ?? new List<int>();
    var timelineApp = ViewBag.ActiveAppForTimeline as StajSistemi.Models.InternshipApplication;
    var approvedCounts = ViewBag.ApprovedCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    bool isAdvisor = User.IsInRole("Advisor") || User.IsInRole("Admin");

    // 🛡️ SİBER TİMELİNE MANTIĞI
    int stepLevel = 0;
    if (timelineApp != null)
    {
        stepLevel = 1; // Başvuru yapıldı
        if (timelineApp.Status == StajSistemi.Models.ApplicationStatus.Approved) stepLevel = 2; // Onaylandı
        if (timelineApp.Status == StajSistemi.Models.ApplicationStatus.Approved && timelineApp.Internship != null && DateTime.Now >= timelineApp.Internship.StartDate) stepLevel = 3; // Staj Başladı
        if (timelineApp.Status == StajSistemi.Models.ApplicationStatus.Approved && timelineApp.Internship != null && DateTime.Now > timelineApp.Internship.EndDate) stepLevel = 4; // Staj Bitti
    }
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
        background-color: #f3f6f9;
        font-family: 'Inter', sans-serif;
    }

    .centered-container {
        max-width: 1250px;
        margin: 0 auto;
        padding: 30px 15px;
    }

    /* 👤 Profil Kartı */
    .profile-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        padding: 25px;
        text-align: center;
        border: none;
    }

    .profile-img {
        width: 100px;
        height: 100px;
        border-radius: 30px;
        border: 4px solid white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        object-fit: cover;
    }

    /* ⏳ TİMELİNE STİLLERİ */
    .timeline-wrapper {
        background: white;
        border-radius: 20px;
        padding: 40px 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .timeline-steps {
        display: flex;
        justify-content: space-between;
        position: relative;
    }

    .timeline-line {
        position: absolute;
        top: 25px;
        left: 5%;
        right: 5%;
        height: 4px;
        background: #e2e8f0;
        z-index: 1;
    }

    .timeline-line-active {
        position: absolute;
        top: 25px;
        left: 5%;
        height: 4px;
        background: #4361ee;
        z-index: 2;
        transition: 1s ease;
        width: @(stepLevel <= 1 ? 0 : (stepLevel == 2 ? 33 : (stepLevel == 3 ? 66 : 90))) %;
    }

    .t-step {
        text-align: center;
        position: relative;
        z-index: 3;
        flex: 1;
    }

    .t-icon {
        width: 50px;
        height: 50px;
        line-height: 50px;
        border-radius: 50%;
        background: white;
        border: 4px solid #e2e8f0;
        display: inline-block;
        transition: 0.3s;
        color: #94a3b8;
        font-size: 1.1rem;
    }

    .t-step.active .t-icon {
        border-color: #4361ee;
        color: #4361ee;
        transform: scale(1.15);
        box-shadow: 0 0 15px rgba(67,97,238,0.2);
    }

    .t-step.completed .t-icon {
        background: #4361ee;
        border-color: #4361ee;
        color: white;
    }

    .t-step.finish .t-icon {
        background: #10b981;
        border-color: #10b981;
        color: white;
    }

    .t-label {
        font-weight: 800;
        margin-top: 15px;
        font-size: 0.8rem;
        color: #1e293b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .t-date {
        font-weight: 700;
        font-size: 0.7rem;
        color: #4361ee;
        margin-top: 5px;
        background: #f0f3ff;
        display: inline-block;
        padding: 2px 8px;
        border-radius: 6px;
    }

    /* 📊 İlan Listesi ve Taşma Çözümü */
    .staj-list-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        padding: 25px;
        border: none;
    }

    .staj-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

    .staj-row td {
        padding: 18px 15px;
        vertical-align: middle;
        background: #ffffff;
        border-top: 1px solid #f1f5f9;
        border-bottom: 1px solid #f1f5f9;
    }

    .quota-badge {
        font-weight: 800;
        font-size: 0.85rem;
        padding: 5px 15px;
        border-radius: 50px;
        white-space: nowrap;
        display: inline-block;
        min-width: 65px;
        text-align: center;
    }

    .badge-program {
        background: #e0f2fe;
        color: #0369a1;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 700;
        border: 1px solid #bae6fd;
        display: inline-block;
        margin: 2px;
    }

    .reco-card {
        border-left: 5px solid #4361ee !important;
        transition: 0.3s;
    }

        .reco-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(67,97,238,0.15);
        }
</style>

<div class="centered-container">
    <div class="row g-4">
        @* --- 👤 SOL: PROFİL KARTI --- *@
        <div class="col-12 col-lg-4 col-xl-3">
            <div class="profile-card sticky-top" style="top: 20px;">
                <img src="https://ui-avatars.com/api/?name=@(Model.Name)+@(Model.Surname)&background=4361ee&color=fff" class="profile-img mb-3">
                <h5 class="fw-bold mb-1">@Model.Name @Model.Surname</h5>
                <p class="text-muted small">@Model.Email</p>
                <div class="text-start mt-3">
                    <label class="text-muted small fw-bold">Program/Bölüm</label>
                    <p class="fw-bold text-primary">@Model.DepartmentName</p>
                </div>
                <a asp-action="EditProfile" class="btn btn-outline-primary w-100 rounded-pill mt-3 py-2 btn-sm fw-bold shadow-sm">
                    <i class="fas fa-user-edit me-1"></i> Profili Güncelle
                </a>
            </div>
        </div>

        @* --- 📊 SAĞ: İÇERİK ALANI --- *@
        <div class="col-12 col-lg-8 col-xl-9">

            @* ✅ 1. ZAMAN ÇİZELGESİ *@
            <div class="timeline-wrapper mb-4 animate__animated animate__fadeIn">
                <h6 class="fw-bold text-muted small mb-4 text-center text-uppercase">Staj Süreci Operasyonel Takibi</h6>
                <div class="timeline-steps">
                    <div class="timeline-line"></div>
                    <div class="timeline-line-active"></div>

                    <div class="t-step @(stepLevel >= 1 ? "completed" : "")">
                        <div class="t-icon"><i class="fas fa-file-signature"></i></div>
                        <div class="t-label">BAŞVURU</div>
                        <div class="t-date">@(timelineApp != null ? timelineApp.ApplicationDate.ToString("dd.MM.yyyy") : "---")</div>
                    </div>

                    <div class="t-step @(stepLevel >= 2 ? "completed" : (stepLevel == 1 ? "active" : ""))">
                        <div class="t-icon"><i class="fas fa-user-check"></i></div>
                        <div class="t-label">ONAY</div>
                        <div class="t-date">
                            @if (timelineApp != null && timelineApp.Status == StajSistemi.Models.ApplicationStatus.Approved)
                            {
                                @timelineApp.ApplicationDate.AddDays(1).ToString("dd.MM.yyyy")
                            }
                            else
                            {
                                <text>BEKLEMEDE</text>
                            }
                        </div>
                    </div>

                    <div class="t-step @(stepLevel >= 3 ? "completed" : (stepLevel == 2 ? "active" : ""))">
                        <div class="t-icon"><i class="fas fa-play-circle"></i></div>
                        <div class="t-label">STAJ</div>
                        <div class="t-date">@(timelineApp?.Internship != null ? timelineApp.Internship.StartDate.ToString("dd.MM.yyyy") : "---")</div>
                    </div>

                    <div class="t-step @(stepLevel >= 4 ? "finish" : (stepLevel == 3 ? "active" : ""))">
                        <div class="t-icon"><i class="fas fa-flag-checkered"></i></div>
                        <div class="t-label">BİTİŞ</div>
                        <div class="t-date">@(timelineApp?.Internship != null ? timelineApp.Internship.EndDate.ToString("dd.MM.yyyy") : "---")</div>
                    </div>
                </div>
            </div>

            @* 2. AKILLI BÖLÜM ÖNERİLERİ *@
            @if (ViewBag.RecommendedInternships != null && ((List<StajSistemi.Models.Internship>)ViewBag.RecommendedInternships).Any())
            {
                <div class="mb-4 animate__animated animate__fadeInUp">
                    <h5 class="fw-bold mb-3 text-dark"><i class="fas fa-magic text-primary me-2"></i>Bölümünüze Özel Öneriler</h5>
                    <div class="row g-3">
                        @foreach (var reco in (List<StajSistemi.Models.Internship>)ViewBag.RecommendedInternships)
                        {
                            <div class="col-md-6 col-xl-4">
                                <div class="card reco-card shadow-sm rounded-4 h-100 border-0">
                                    <div class="card-body p-3">
                                        <h6 class="fw-bold mb-1 text-truncate">@reco.CompanyName</h6>
                                        <p class="small text-muted mb-3"><i class="fas fa-map-marker-alt me-1"></i> @(reco.City?.Name ?? "Şehir Belirtilmemiş")</p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="badge bg-success-subtle text-success rounded-pill">Sizin İçin Uygun</span>
                                            <a asp-action="Apply" asp-route-id="@reco.Id" class="btn btn-primary btn-sm rounded-pill px-3">İncele</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @* 3. TÜM İLANLAR *@
            <div class="staj-list-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0 text-dark"><i class="fas fa-list text-primary me-2"></i>Aktif İlanlar</h5>
                    <a asp-action="Index" asp-route-filter="@(ViewBag.FilterMode == "suitable" ? "all" : "suitable")" class="btn btn-sm btn-info text-white rounded-pill shadow-sm">
                        @(ViewBag.FilterMode == "suitable" ? "Tümünü Göster" : "Bölümüme Uygun Olanlar")
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="staj-table">
                        <tbody>
                            @if (ViewBag.SmartMatches != null)
                            {
                                foreach (dynamic match in ViewBag.SmartMatches)
                                {
                                    int approved = approvedCounts.ContainsKey(match.Ilan.Id) ? approvedCounts[match.Ilan.Id] : 0;
                                    bool isFull = approved >= match.Ilan.Quota;
                                    bool alreadyApplied = appliedIds.Contains(match.Ilan.Id);

                                    <tr class="staj-row">
                                        <td><div class="fw-bold text-dark">@match.Ilan.CompanyName</div><small class="text-muted">@match.Ilan.City?.Name</small></td>
                                        <td>
                                            @foreach (var deptMap in match.Ilan.InternshipDepartments)
                                            {
                                                <span class="badge-program">@(deptMap.Department?.DepartmentName ?? "Bölüm")</span>
                                            }
                                        </td>
                                        <td class="text-center"><span class="quota-badge border">@approved / @match.Ilan.Quota</span></td>
                                        <td class="text-center">
                                            @if (isFull)
                                            {
                                                <button class="btn btn-sm btn-secondary rounded-pill px-4 disabled">DOLU</button>
                                            }
                                            else if (alreadyApplied)
                                            {
                                                <button class="btn btn-sm btn-success rounded-pill px-4 disabled"><i class="fas fa-check me-1"></i>BAŞVURULDU</button>
                                            }
                                            else
                                            {
                                                <a asp-action="Apply" asp-route-id="@match.Ilan.Id" class="btn btn-sm btn-primary rounded-pill px-4 shadow-sm fw-bold">Başvur</a>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (TempData["DeptMismatch"] != null)
        {
            <text>
                    Swal.fire({
                        title: 'Bölüm Uygunluk Bildirimi',
                        text: 'Seçtiğiniz ilan, akademik programınızın kriterleriyle tam olarak örtüşmemektedir. Kariyer gelişiminize en yüksek katkıyı sağlayabilecek, bölümünüze özel staj fırsatlarını sizin için aşağıda listeledik.',
                        icon: 'info',
                        confirmButtonColor: '#4361ee',
                        confirmButtonText: 'Önerileri Göster'
                    });
            </text>
        }
    </script>
}