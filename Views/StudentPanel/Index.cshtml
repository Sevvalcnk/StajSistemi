@{
    ViewData["Title"] = "Öğrenci Paneli";
}
<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4 p-5 bg-white">
        <div class="text-center mb-4">
            <i class="fas fa-user-graduate fa-4x text-primary mb-3"></i>
            <h2 class="fw-bold" style="color: #2c3e50;">Öğrenci Takip Sistemi</h2>
            <p class="text-muted">Staj durumunuzu ve akademik verilerinizi anlık takip edin.</p>
        </div>
        <div class="alert alert-info border-0 rounded-pill ps-4 shadow-sm">
            <i class="fas fa-info-circle me-2"></i> Şuan aktif bir staj başvurunuz bulunmamaktadır.
        </div>
        <div class="d-grid mt-4">
            <button class="btn btn-primary btn-lg rounded-pill py-3 fw-bold shadow">
                <i class="fas fa-plus-circle me-2"></i>Yeni Staj Başvurusu Yap
            </button>
        </div>
    </div>
</div>