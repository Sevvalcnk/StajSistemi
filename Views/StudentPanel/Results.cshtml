@using StajSistemi.Models @* 🛡️ Yeni etiketleri tanımak için bu mühür şart! *@
@model List<StajSistemi.Models.InternshipApplication>

@{
    ViewData["Title"] = "Staj Sonuçlarım";
}

<div class="container py-4 techNode-fade-in">
    <div class="glass-card p-4 shadow-lg border-0 rounded-4 bg-white">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0 text-dark">
                <i class="fas fa-poll-h text-info me-2"></i>Staj Başvuru Sonuçları
            </h3>
            <span class="badge bg-info-subtle text-info border border-info-subtle px-4 py-2 rounded-pill fw-bold shadow-sm">
                <i class="fas fa-check-double me-1"></i> Kesin Sonuç Listesi
            </span>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-3 border-0">Şirket / Kurum</th>
                            <th class="border-0">Başvuru Tarihi</th>
                            <th class="border-0 text-center">Başarı Skoru (4.00)</th> @* ✅ İSİM GÜNCELLENDİ *@
                            <th class="border-0 text-center">Durum</th>
                            <th class="text-center border-0 pe-3">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-dark">
                                    <i class="fas fa-building text-muted me-2 small"></i>@(app.Internship?.CompanyName ?? "Şirket Bilgisi Yok")
                                </td>
                                <td class="text-muted">@app.ApplicationDate.ToString("dd.MM.yyyy")</td>
                                <td class="text-center">
                                    @* ✅ AKADEMİK SKOR TAMİRİ: 100.0'e bölerek 2.85 formatına çekiyoruz *@
                                    @{
                                        double academicScore = app.SuccessScore / 100.0;
                                    }
                                    <div class="badge @(academicScore >= 3.0 ? "bg-success" : "bg-primary") text-white px-3 py-2 rounded-3 shadow-sm fw-bold">
                                        <i class="fas fa-graduation-cap me-1"></i>
                                        @academicScore.ToString("0.00") @* Artık 2.85 olarak görünecek! *@
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (app.Status == ApplicationStatus.Approved)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill fw-bold">
                                            <i class="fas fa-check-circle me-1"></i> Onaylandı
                                        </span>
                                    }
                                    else if (app.Status == ApplicationStatus.Rejected)
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 rounded-pill fw-bold">
                                            <i class="fas fa-times-circle me-1"></i> Sonuçlandı
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-pill fw-bold text-dark">
                                            <i class="fas fa-clock me-1"></i> Beklemede
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details"
                                       asp-route-id="@app.Id"
                                       class="btn btn-sm btn-outline-info rounded-pill px-4 fw-bold shadow-sm transition hover-up">
                                        <i class="fas fa-search-plus me-1"></i> Detaylar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 opacity-50">
                <i class="fas fa-hourglass-start fa-3x text-muted mb-3"></i>
                <p class="text-muted fw-bold">Henüz sonuçlanmış bir staj başvurunuz bulunmamaktadır.</p>
                <small>Değerlendirme süreci tamamlandığında akademik sonuçlarınız burada listelenecektir. 😊</small>
            </div>
        }
    </div>
</div>

<style>
    /* Kurumsal Estetik Dokunuşlar */
    .bg-success-subtle {
        background-color: #e8f5e9 !important;
    }

    .bg-danger-subtle {
        background-color: #ffebee !important;
    }

    .bg-warning-subtle {
        background-color: #fff9c4 !important;
    }

    .bg-info-subtle {
        background-color: #e3f2fd !important;
    }

    .transition {
        transition: all 0.3s ease;
    }

    .hover-up:hover {
        transform: translateY(-3px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 184, 212, 0.02);
    }
</style>